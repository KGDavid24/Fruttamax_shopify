            "custom_liquid_HL7FHB": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% liquid\n  assign seconds_in_two_days = 2 | times: 24 | times: 60 | times: 60\n  assign delivery_timestamp = 'now' | date: \"%s\" | plus: seconds_in_two_days\n  assign delivery_date = delivery_timestamp | date: \"%d.%m.%Y\"\n%}\n\n<div class=\"modern-dynamic-delivery-card\">\n  <div class=\"card-content-wrapper\">\n    <div class=\"delivery-icon-static\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#d92121\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"></rect>\n        <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"></polygon>\n        <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"></circle>\n        <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"></circle>\n      </svg>\n    </div>\n    <div class=\"delivery-text-info\">\n      <div class=\"main-delivery-line\">\n        <span class=\"label-text\">\n          {% if request.locale.iso_code == 'hu' %}\n            Várható szállítás:\n          {% else %}\n            Livrare estimată:\n          {% endif %}\n        </span>\n        <strong class=\"date-text\">{{ delivery_date }}</strong>\n      </div>\n      <div class=\"sub-delivery-line\">\n        <span class=\"status-indicator\"></span>\n        <span>\n          {% if request.locale.iso_code == 'hu' %}\n            Átlagos szállítási idő: 2 munkanap\n          {% else %}\n            Timp mediu de tranzit: 2 zile lucrătoare\n          {% endif %}\n        </span>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"dynamic-progress-container\">\n    <div class=\"dynamic-progress-bar\"></div>\n  </div>\n</div>\n\n<style>\n  .modern-dynamic-delivery-card {\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    padding: 18px 20px;\n    background-color: #ffffff; \n    border-radius: 12px;\n    border: 1px solid rgba(0,0,0,0.06);\n    box-shadow: 0 4px 15px rgba(0,0,0,0.03);\n    margin-bottom: 20px;\n    overflow: hidden; \n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  .modern-dynamic-delivery-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 6px 20px rgba(0,0,0,0.05);\n  }\n\n  .card-content-wrapper {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .delivery-icon-static {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 44px;\n    height: 44px;\n    background-color: rgba(217, 33, 33, 0.06); \n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n\n  .delivery-text-info {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .main-delivery-line {\n    display: flex;\n    align-items: baseline;\n    gap: 6px;\n    flex-wrap: wrap;\n  }\n\n  /* Finomabb vastagság, fekete/sötétszürke szín */\n  .label-text {\n    font-size: 0.85rem;\n    font-weight: 500;\n    color: #333333; \n  }\n\n  /* Visszavettük a vastagságot (800-ról 600-ra) */\n  .date-text {\n    font-size: 1rem;\n    font-weight: 600;\n    color: #111111; \n  }\n\n  /* Fekete/sötétszürke alsó szöveg, normál (400) vastagsággal */\n  .sub-delivery-line {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 0.85rem;\n    color: #444444; \n    font-weight: 400;\n  }\n\n  .status-indicator {\n    display: inline-block;\n    width: 6px;\n    height: 6px;\n    background-color: #108043; \n    border-radius: 50%;\n  }\n\n  .dynamic-progress-container {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    height: 4px; \n    background-color: rgba(217, 33, 33, 0.08); \n  }\n\n  .dynamic-progress-bar {\n    height: 100%;\n    width: 25%; \n    background: linear-gradient(90deg, #ff4d4d 0%, #d92121 100%); \n    border-radius: 0 4px 4px 0;\n    animation: slide-progress-clean 2.8s ease-in-out infinite alternate;\n  }\n\n  @keyframes slide-progress-clean {\n    0% { transform: translateX(0); width: 15%; }\n    100% { transform: translateX(566%); width: 15%; } \n  }\n</style>"
