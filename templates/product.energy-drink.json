            "custom_liquid_YpAcTQ": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "disabled": true,
              "settings": {
                "custom_liquid": "{% assign mf = product.metafields.custom %}\n{% if mf.bucati_carton != blank or mf.ambalaj != blank or mf.ean_produs != blank or mf.data_expirarii_luna != blank %}\n\n  <div style=\"\n    margin: 0; \n    padding: 14px 18px; \n    background-color: rgba(232, 4, 4, 0.06); \n    border-radius: 8px; \n    display: flex; \n    flex-direction: column; \n    gap: 10px; /* Picit megnövelt sorköz, hogy az ikonok jól mutassanak */\n    font-family: inherit;\n  \">\n    \n    <h3 style=\"\n      color: #E80404; \n      font-weight: 900; \n      font-size: 1.1rem; \n      margin: 0 0 6px 0; \n      letter-spacing: 0.02em;\n    \">\n      Specificații Produs\n    </h3>\n    \n    {% if mf.bucati_carton != blank %}\n      <div style=\"display: flex; gap: 8px; align-items: center;\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E80404\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"flex-shrink: 0;\">\n          <path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"></path>\n          <polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"></polyline>\n          <line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"></line>\n        </svg>\n        <span style=\"color: #E80404; font-weight: 600; font-size: 0.95rem;\">Bucăți / Carton:</span>\n        <span style=\"font-weight: 700; font-size: 0.95rem; color: inherit;\">{{ mf.bucati_carton }}</span>\n      </div>\n    {% endif %}\n    \n    {% if mf.ambalaj != blank %}\n      <div style=\"display: flex; gap: 8px; align-items: center;\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E80404\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"flex-shrink: 0;\">\n          <path d=\"M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z\"></path>\n          <line x1=\"7\" y1=\"7\" x2=\"7.01\" y2=\"7\"></line>\n        </svg>\n        <span style=\"color: #E80404; font-weight: 600; font-size: 0.95rem;\">Ambalaj:</span>\n        <span style=\"font-weight: 700; font-size: 0.95rem; color: inherit;\">{{ mf.ambalaj }}</span>\n      </div>\n    {% endif %}\n    \n    {% if mf.ean_produs != blank %}\n      <div style=\"display: flex; gap: 8px; align-items: center;\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E80404\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"flex-shrink: 0;\">\n          <line x1=\"3\" y1=\"5\" x2=\"3\" y2=\"19\"></line>\n          <line x1=\"8\" y1=\"5\" x2=\"8\" y2=\"19\"></line>\n          <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line>\n          <line x1=\"16\" y1=\"5\" x2=\"16\" y2=\"19\"></line>\n          <line x1=\"21\" y1=\"5\" x2=\"21\" y2=\"19\"></line>\n        </svg>\n        <span style=\"color: #E80404; font-weight: 600; font-size: 0.95rem;\">EAN Produs:</span>\n        <span style=\"font-weight: 700; font-size: 0.95rem; color: inherit;\">{{ mf.ean_produs }}</span>\n      </div>\n    {% endif %}\n    \n    {% if mf.data_expirarii_luna != blank %}\n      <div style=\"display: flex; gap: 8px; align-items: center;\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E80404\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"flex-shrink: 0;\">\n          <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect>\n          <line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"></line>\n          <line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"></line>\n          <line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"></line>\n        </svg>\n        <span style=\"color: #E80404; font-weight: 600; font-size: 0.95rem;\">Dată Expirare (Luni):</span>\n        <span style=\"font-weight: 700; font-size: 0.95rem; color: inherit;\">{{ mf.data_expirarii_luna }}</span>\n      </div>\n    {% endif %}\n    \n  </div>\n\n{% endif %}"
