            "custom_liquid_qpMzCT": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% assign current_lang = localization.language.iso_code | downcase %}\n\n{% if product.metafields.custom.fisa_produsului != blank %}\n  <a href=\"{{ product.metafields.custom.fisa_produsului.value.url }}\"\n     target=\"_blank\"\n     class=\"modern-pdf-button\">\n    <span>\n      {% case current_lang %}\n        {% when 'hu' %}\n          Termékadatlap\n        {% when 'ro' %}\n          Fișa produsului\n        {% else %}\n          Product sheet\n      {% endcase %}\n    </span>\n\n    <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"pdf-icon\">\n      <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"></path>\n      <polyline points=\"14 2 14 8 20 8\"></polyline>\n      <line x1=\"12\" y1=\"18\" x2=\"12\" y2=\"12\"></line>\n      <polyline points=\"9 15 12 18 15 15\"></polyline>\n    </svg>\n  </a>\n\n  <style>\n    .modern-pdf-button {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      background: linear-gradient(135deg, #E80404 0%, #c40303 100%);\n      color: #ffffff !important;\n      padding: 8px 16px;\n      text-decoration: none;\n      border-radius: 8px;\n      font-weight: 600;\n      font-size: 0.85rem;\n      letter-spacing: 0.3px;\n      text-transform: uppercase;\n      margin: 8px 0;\n      border: 1px solid #b30000;\n      cursor: pointer;\n      box-shadow: 0 3px 8px rgba(232, 4, 4, 0.2);\n      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\n    }\n\n    .modern-pdf-button:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 5px 15px rgba(232, 4, 4, 0.3);\n      background: linear-gradient(135deg, #f20f0f 0%, #d10404 100%);\n    }\n\n    .modern-pdf-button .pdf-icon {\n      flex-shrink: 0;\n      transition: transform 0.3s ease;\n    }\n\n    .modern-pdf-button:hover .pdf-icon {\n      transform: translateY(2px);\n    }\n  </style>\n{% endif %}"
