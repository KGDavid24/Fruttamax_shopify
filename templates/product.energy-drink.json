            "custom_liquid_mUPPwj": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "disabled": true,
              "settings": {
                "custom_liquid": "<style>\n  .custom-accordion {\n    border-top: 1px solid #e5e5e5;\n    border-bottom: 1px solid #e5e5e5;\n    margin: 10px 0;\n    width: 100%;\n  }\n  .accordion-header {\n    padding: 15px 0;\n    cursor: pointer;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-weight: 600;\n    font-size: 14px;\n    color: #000;\n  }\n  .accordion-header::after {\n    content: '+';\n    font-size: 18px;\n  }\n  .custom-accordion[open] .accordion-header::after {\n    content: '-';\n  }\n  .accordion-content {\n    padding: 0 0 15px 0;\n    font-size: 13px;\n    line-height: 1.6;\n    color: #333;\n  }\n  .nutri-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 10px;\n  }\n  .nutri-table tr { border-bottom: 1px solid #f1f1f1; }\n  .nutri-table td { padding: 8px 0; }\n  .text-right { text-align: right; }\n  .warn-red { color: #d9534f; font-weight: bold; }\n</style>\n\n<details class=\"custom-accordion\">\n  <summary class=\"accordion-header\">\n    {% if request.locale.iso_code == 'ro' %}\n      Informații nutriționale și Ingrediente\n    {% else %}\n      Tápérték és Összetevők\n    {% endif %}\n  </summary>\n  <div class=\"accordion-content\">\n    \n    {% if request.locale.iso_code == 'ro' %}\n      {% comment %} ROMÁN TARTALOM {% endcomment %}\n      <p><strong>Ingrediente:</strong> Aici introduceți lista ingredientelor în limba română de pe etichetă...</p>\n      <table class=\"nutri-table\">\n        <thead><tr style=\"font-weight: bold;\"><td>100ml</td><td class=\"text-right\">Valoare</td></tr></thead>\n        <tbody>\n          <tr><td>Valoare energetică</td><td class=\"text-right\">XX kJ / XX kcal</td></tr>\n          <tr><td>Grăsimi</td><td class=\"text-right\">0 g</td></tr>\n          <tr><td>Glucide</td><td class=\"text-right\">XX g</td></tr>\n          <tr><td>din care zaharuri</td><td class=\"text-right\">XX g</td></tr>\n          <tr><td>Proteine</td><td class=\"text-right\">0 g</td></tr>\n          <tr class=\"warn-red\"><td>Cofeină</td><td class=\"text-right\">XX mg</td></tr>\n        </tbody>\n      </table>\n      <p style=\"margin-top:10px; font-size: 11px; color: #666;\">Raport diluție recomandat: 1:23.</p>\n\n    {% else %}\n      {% comment %} MAGYAR TARTALOM {% endcomment %}\n      <p><strong>Összetevők:</strong> Ide írd be a magyar nyelvű összetevők listáját a címkéről...</p>\n      <table class=\"nutri-table\">\n        <thead><tr style=\"font-weight: bold;\"><td>100ml</td><td class=\"text-right\">Érték</td></tr></thead>\n        <tbody>\n          <tr><td>Energia</td><td class=\"text-right\">XX kJ / XX kcal</td></tr>\n          <tr><td>Zsír</td><td class=\"text-right\">0 g</td></tr>\n          <tr><td>Szénhidrát</td><td class=\"text-right\">XX g</td></tr>\n          <tr><td>amelyből cukrok</td><td class=\"text-right\">XX g</td></tr>\n          <tr><td>Fehérje</td><td class=\"text-right\">0 g</td></tr>\n          <tr class=\"warn-red\"><td>Koffein</td><td class=\"text-right\">XX mg</td></tr>\n        </tbody>\n      </table>\n      <p style=\"margin-top:10px; font-size: 11px; color: #666;\">Ajánlott hígítási arány: 1:23.</p>\n    {% endif %}\n\n  </div>\n</details>"
