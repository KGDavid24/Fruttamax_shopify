            "custom_liquid_yWhL77": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  .hasonlo-termekek-wrapper {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    align-items: center;\n    margin: 10px 0;\n  } \n\n  .hasonlo-termek {\n    text-decoration: none;\n    display: inline-block;\n  }\n\n  /* Alap Pill stílus */\n  .termek-varians-pill {\n    display: inline-block;\n    padding: 8px 18px;\n    background-color: #ffffff;\n    border: 1px solid #000000;\n    border-radius: 50px;\n    font-size: 14px;\n    font-weight: 500;\n    color: #000000;\n    transition: all 0.2s ease;\n    cursor: pointer;\n    text-align: center;\n    min-width: 85px;\n    line-height: 1.2;\n  }\n\n  /* Aktív állapot - Amikor ezen a termékoldalon vagyunk */\n  .termek-varians-pill.active-selection {\n    background-color: #000000; /* Fekete háttér */\n    color: #ffffff;            /* Fehér szöveg */\n    cursor: default;           /* Ne mutasson kattintható kurzort, mert már itt vagyunk */\n    pointer-events: none;      /* Ne lehessen újra rákattintani */\n  }\n\n  /* Hover effekt csak a nem aktív gombokra */\n  .hasonlo-termek:not(.is-active):hover .termek-varians-pill {\n    background-color: #f0f0f0;\n    transform: translateY(-1px);\n  }\n\n  .hasonlo-toggle-card {\n    display: inline-block;\n    padding: 8px 18px;\n    background-color: #eeeeee;\n    border-radius: 50px;\n    font-size: 14px;\n    cursor: pointer;\n    color: #555555;\n    border: 1px solid transparent;\n  }\n\n  .hasonlo-szin-kijelzo {\n    margin-top: 8px;\n    font-size: 13px;\n    font-weight: 600;\n    color: #333333;\n    min-height: 1.4em;\n  }\n\n  @media (max-width: 600px) {\n    .termek-varians-pill {\n      padding: 6px 14px;\n      font-size: 13px;\n      min-width: 75px;\n    }\n  }\n</style>\n\n{% assign current_product_handle = product.handle %}\n{% assign raw_handles = product.metafields.custom.hasonlo_termekek_handle \n  | remove: '[' | remove: ']' | remove: '\"' | split: ',' %}\n{% assign hasonlo_count = raw_handles.size %}\n\n{% if hasonlo_count > 0 %}\n  <div class=\"hasonlo-termekek-wrapper\" id=\"hasonlo-termekek\">\n    {% assign index_counter = 0 %}\n    {% for handle in raw_handles %}\n      {% assign trimmed_handle = handle | strip %}\n      {% assign termek = all_products[trimmed_handle] %}\n      \n      {% if termek and termek.url %}\n        {% assign has_available_variant = false %}\n        {% for variant in termek.variants %}\n          {% if variant.available %}\n            {% assign has_available_variant = true %}\n            {% break %}\n          {% endif %}\n        {% endfor %}\n\n        {% if has_available_variant %}\n          {% assign index_counter = index_counter | plus: 1 %}\n\n          {% comment %} Név meghatározása és formázása {% endcomment %}\n          {% if trimmed_handle contains 'light' %}\n            {% assign display_name = 'Light' %}\n          {% else %}\n            {% assign display_name = 'Normal' %}\n          {% endif %}\n\n          {% comment %} Aktív állapot vizsgálata {% endcomment %}\n          {% assign is_active = false %}\n          {% if current_product_handle == trimmed_handle %}\n            {% assign is_active = true %}\n          {% endif %}\n\n          {% if index_counter == 10 and hasonlo_count > 10 %}\n            <div class=\"hasonlo-termek\">\n              <div id=\"toggle-hasonlo\" class=\"hasonlo-toggle-card\" data-expanded=\"false\">\n                + Több\n              </div>\n            </div>\n            \n            <a href=\"{{ termek.url }}\" \n               class=\"hasonlo-termek {% if is_active %}is-active{% endif %}\" \n               data-szin=\"{{ termek.metafields.custom.szin }}\" \n               style=\"display:none;\">\n              <span class=\"termek-varians-pill {% if is_active %}active-selection{% endif %}\">\n                {{ display_name }}\n              </span>\n            </a>\n          {% else %}\n            <a href=\"{{ termek.url }}\" \n               class=\"hasonlo-termek {% if is_active %}is-active{% endif %}\" \n               data-szin=\"{{ termek.metafields.custom.szin }}\"\n               {% if index_counter > 10 %}style=\"display:none;\"{% endif %}>\n              <span class=\"termek-varians-pill {% if is_active %}active-selection{% endif %}\">\n                {{ display_name }}\n              </span>\n            </a>\n          {% endif %}\n        {% endif %}\n      {% endif %}\n    {% endfor %}\n  </div>\n\n  <div class=\"hasonlo-szin-kijelzo\" id=\"hasonlo-szin-kijelzo\"></div>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', function() {\n      const wrapper = document.getElementById('hasonlo-termekek');\n      if (!wrapper) return;\n\n      const items = wrapper.querySelectorAll('.hasonlo-termek');\n      const szinKijelzo = document.getElementById('hasonlo-szin-kijelzo');\n      const toggle = document.getElementById('toggle-hasonlo');\n      \n      items.forEach(item => {\n        if (!item.contains(toggle)) {\n          item.addEventListener('mouseenter', () => {\n            const szin = item.getAttribute('data-szin');\n            if(szin) szinKijelzo.textContent = 'Szín: ' + szin;\n          });\n          item.addEventListener('mouseleave', () => {\n            szinKijelzo.textContent = '';\n          });\n        }\n      });\n\n      if (toggle) {\n        toggle.addEventListener('click', function() {\n          const isExpanded = this.getAttribute('data-expanded') === 'true';\n          const hiddenPills = wrapper.querySelectorAll('.hasonlo-termek[style*=\"display:none\"]');\n          const allPills = Array.from(items).filter(i => !i.contains(toggle));\n\n          if (isExpanded) {\n            allPills.forEach((pill, index) => {\n              if(index >= 9) pill.style.display = 'none';\n            });\n            this.textContent = '+ Több';\n            this.setAttribute('data-expanded', 'false');\n          } else {\n            allPills.forEach(pill => pill.style.display = 'inline-block');\n            this.textContent = '- Kevesebb';\n            this.setAttribute('data-expanded', 'true');\n          }\n        });\n      }\n    });\n  </script>\n{% endif %}"
