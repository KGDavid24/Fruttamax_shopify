{%- style -%}
  /* FŐ SZEKCIÓ (Full Width Háttér) */
  .section-{{ section.id }}-root {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #111;
    overflow: hidden;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  /* HÁTTÉRKÉP */
  .review-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* SZÍNES OVERLAY */
  .review-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, {{ section.settings.brand_color }} 0%, #000000 100%);
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  /* TARTALOM KONTÉNER - FIX 1200PX */
  .review-content-wrapper {
    position: relative;
    z-index: 2;
    max-width: 1200px; /* Átállítva 1300-ról 1200-ra */
    margin: 0 auto;
    padding: 0 20px;
  }

  /* CÍMSOR */
  .review-heading {
    text-align: center;
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 60px;
    color: #ffffff;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  /* SLIDER KONTÉNER */
  .review-slider-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* A GÖRGETHETŐ SÁV (TRACK) */
  .review-slider-track {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    
    /* Hely a kártyák körül */
    padding: 20px 20px 40px 20px; 
    
    scrollbar-width: none; /* Firefox scrollbar rejtés */
    -ms-overflow-style: none; /* IE/Edge */
    width: 100%;
    scroll-behavior: smooth;
    
    justify-content: flex-start; 
  }
   
  .review-slider-track::-webkit-scrollbar {
    display: none; /* Chrome/Safari scrollbar rejtés */
  }

  /* REVIEW KÁRTYA */
  .review-card {
    /* Mobilon szélesebb */
    flex: 0 0 85%; 
    max-width: 400px;
    
    scroll-snap-align: center;
    
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 35px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease;
    min-height: 350px;
  }

  @media screen and (min-width: 990px) {
    .review-card {
      flex: 0 0 380px; /* Desktopon fix szélesség */
    }
  }

  .review-card:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-5px);
  }

  /* TERMÉK NÉV */
  .review-product {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 15px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* CSILLAGOK */
  .review-stars {
    color: #FFD700;
    margin-bottom: 20px;
    font-size: 1.4rem;
  }

  /* SZÖVEG */
  .review-text {
    font-size: 1.2rem;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 25px;
    opacity: 0.95;
    flex-grow: 1;
  }

  /* SZERZŐ */
  .review-author {
    font-weight: 700;
    font-size: 1.2rem;
    text-align: right;
    color: #ffffff;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 15px;
  }

  /* NYILAK (Navigáció) */
  .review-nav-btn {
    background: rgba(0, 0, 0, 0.6); /* Sötétebb háttér */
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20; /* Magasabb z-index */
    transition: all 0.3s;
    outline: none;
  }

  .review-nav-btn:hover {
    background: {{ section.settings.brand_color }};
    border-color: {{ section.settings.brand_color }};
    transform: translateY(-50%) scale(1.1); /* Fix transform */
  }

  .review-prev { left: -25px; }
  .review-next { right: -25px; }

  @media screen and (max-width: 990px) {
    .review-nav-btn { display: none; }
    
    .review-slider-track {
      padding-right: 50px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-root">
  
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'review-bg-image', alt: 'Reviews Background' }}
  {%- endif -%}

  <div class="review-overlay"></div>

  <div class="review-content-wrapper">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="review-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="review-slider-container">
      
      <button class="review-nav-btn review-prev" aria-label="Previous" onclick="scrollReviews_{{ section.id | replace: '-', '_' }}('left')">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="review-slider-track" id="slider-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="review-card" {{ block.shopify_attributes }}>
            
            <div class="review-product">{{ block.settings.product_name }}</div>
            
            <div class="review-stars">
              {%- assign rating = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}★{%- else -%}☆{%- endif -%}
              {%- endfor -%}
            </div>

            <div class="review-text">"{{ block.settings.text }}"</div>
            
            <div class="review-author">{{ block.settings.author }}</div>
          
          </div>
        {%- endfor -%}
      </div>

      <button class="review-nav-btn review-next" aria-label="Next" onclick="scrollReviews_{{ section.id | replace: '-', '_' }}('right')">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>

    </div>
  </div>
</div>

<script>
  // A függvény neve most már tartalmazza az aláhúzást, így nem okoz hibát a kötőjel
  function scrollReviews_{{ section.id | replace: '-', '_' }}(direction) {
    const slider = document.getElementById('slider-{{ section.id }}');
    
    // Megkeressük az első kártyát, hogy pontosan tudjuk a szélességet
    const card = slider.querySelector('.review-card');
    
    // Ha van kártya, akkor szélesség + 30px gap, ha nincs, akkor 410px fallback
    const scrollAmount = card ? card.offsetWidth + 30 : 410; 
    
    if (direction === 'left') {
      slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
      slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  }
</script>

