{%- style -%}
  /* FULL WIDTH BREAKOUT (Háttér kifut a széléig) */
  .section-{{ section.id }}-full-width {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  /* BELSŐ KONTÉNER (Page Width) - FIX 1200PX */
  .custom-video-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column; /* Egymás alá rendezés (Cím + Videó) */
    align-items: center;    /* Vízszintesen középre */
    width: 100%;
  }

  /* CÍMSOR STÍLUS */
  .custom-video-heading {
    text-align: center;
    /* System Font */
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    color: {{ section.settings.heading_color }};
    margin: 0 0 40px 0; /* Alsó margó a videóig */
    line-height: 1.2;
    max-width: 900px;
  }

  /* VIDEÓ DOBOZ - FIX 1200PX */
  .custom-video-wrapper {
    width: 100%;
    max-width: 1200px; /* Fixen 1200px, nem a beállítástól függ */
    
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0,0,0,0.15); /* Kicsit erősebb árnyék */
    background-color: #000;
    line-height: 0;
  }

  .custom-video-wrapper video,
  .custom-video-wrapper iframe {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
  }

  /* MOBILON */
  @media screen and (max-width: 750px) {
    .section-{{ section.id }}-full-width {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    .custom-video-heading {
      font-size: 1.8rem; /* Kisebb betűméret mobilon */
      margin-bottom: 30px;
    }

    .custom-video-wrapper {
      max-width: 100% !important;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-full-width">
  <div class="custom-video-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-video-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="custom-video-wrapper">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: 
          image_size: '1200x', 
          autoplay: section.settings.autoplay, 
          loop: section.settings.loop, 
          controls: section.settings.controls, 
          muted: section.settings.autoplay, 
          preload: 'none' 
        }}
      {%- else -%}
        <div style="padding: 100px; text-align: center; color: white; background: #333;">
          <p>Selectează un video.</p>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Video Centrat + Titlu",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Conținut"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titlu Secțiune",
      "default": "Vezi cum se prepară"
    },
    {
      "type": "header",
      "content": "Setări Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Selectează Video (MP4 Shopify)"
    },
    {
      "type": "range",
      "id": "video_width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Lățime Maximă Video (Desktop)",
      "default": 1200
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (Mute obligatoriu)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop (Repetare)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Arată butoane control",
      "default": true
    },
    {
      "type": "header",
      "content": "Design & Culori"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Culoare Fundal (Full Width)",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Culoare Titlu",
      "default": "#E80404"
    },
    {
      "type": "header",
      "content": "Spațiere"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Sus",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Jos",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Video Centrat + Titlu"
    }
  ]
}
{% endschema %}