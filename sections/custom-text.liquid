      "content": "Butoane (Gombok)"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Text Buton 1 (Plin)",
      "default": "Arome"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Link Buton 1"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Text Buton 2 (Contur)",
      "default": "Magazin Online"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Link Buton 2"
    },
    {
      "type": "header",
      "content": "Spațiere (Padding)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
