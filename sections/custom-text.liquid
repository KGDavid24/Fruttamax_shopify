    {
      "type": "color",
      "id": "text_color",
      "label": "Culoare Text Normal",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Culoare Titlu",
      "default": "#E80404"
    },
    {
      "type": "header",
      "content": "Conținut (Tartalom)"
    },
    {
