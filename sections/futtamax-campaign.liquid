<div id="toast"></div>

<script>
/* ── Scroll reveal ── */
const obs = new IntersectionObserver(entries => entries.forEach(e => {
  if (e.isIntersecting) e.target.classList.add('vis');
}), { threshold: 0.08 });
document.querySelectorAll('#fruttamax-campaign-wrapper .reveal').forEach(el => obs.observe(el));

/* ── File upload ── */
const dzEl   = document.getElementById('dz');
const fileIn = document.getElementById('file-in');
const pw     = document.getElementById('prev-wrap');
const pi     = document.getElementById('prev-img');
const pn     = document.getElementById('prev-name');
const ps     = document.getElementById('prev-size');
const rm     = document.getElementById('rm-btn');

/* Locale flag injected from Liquid so JS toast messages match the page language */
const isHu = {{ is_hu | json }};

dzEl.addEventListener('dragover',  e => { e.preventDefault(); dzEl.classList.add('over'); });
dzEl.addEventListener('dragleave', () => dzEl.classList.remove('over'));
dzEl.addEventListener('drop', e => {
  e.preventDefault(); dzEl.classList.remove('over');
  if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});
fileIn.addEventListener('change', () => { if (fileIn.files[0]) handleFile(fileIn.files[0]); });

function handleFile(f) {
  const isImageMime = f.type.startsWith('image/');
  const isHeicExt = f.name.toLowerCase().endsWith('.heic') || f.name.toLowerCase().endsWith('.heif');

  if (!isImageMime && !isHeicExt) {
    toast(isHu ? '⚠️ Válassz egy képet.' : '⚠️ Selectează o imagine.');
    return;
  }
  if (f.size > 5 * 1024 * 1024) {
    toast(isHu ? '⚠️ A kép mérete meghaladja az 5MB-ot.' : '⚠️ Imaginea depășește 5MB.');
    return;
  }

  const r = new FileReader();
  r.onload = ev => {
    if (isHeicExt) {
      pi.style.display = 'none';
    } else {
      pi.style.display = 'block';
      pi.src = ev.target.result;
    }
    pn.textContent = f.name;
    ps.textContent = (f.size / 1024 / 1024).toFixed(2) + ' MB';
    pw.style.display = 'flex';
    dzEl.style.display = 'none';
  };
  r.readAsDataURL(f);
}

rm.addEventListener('click', () => {
  fileIn.value = '';
  pw.style.display = 'none';
  dzEl.style.display = 'block';
  pi.src = '';
  pi.style.display = 'block';
});

/* ── Form submit ── */
document.getElementById('main-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const nume       = this.querySelector('[name="nume"]').value.trim();
  const email      = this.querySelector('[name="email"]').value.trim();
  const tel        = this.querySelector('[name="tel"]').value.trim();
  const newsletter = document.getElementById('newsletter').checked;

  if (!nume) {
    toast(isHu ? '⚠️ Add meg a nevedet.' : '⚠️ Introdu numele tău.');
    return;
  }
  if (!email || !email.includes('@')) {
    toast(isHu ? '⚠️ Adj meg egy érvényes e-mail címet.' : '⚠️ Introdu un email valid.');
    return;
  }
  if (!fileIn.files.length) {
    toast(isHu ? '⚠️ Csatold a fotódat.' : '⚠️ Atașează fotografia ta.');
    return;
  }
  if (fileIn.files[0].size > 15 * 1024 * 1024) {
    toast(isHu ? '⚠️ A fotó túl nagy. Maximum 15MB.' : '⚠️ Fotografia este prea mare. Maximum 15MB.');
    return;
  }

  const f = fileIn.files[0];
  const isImageMimeSubmit = f.type.startsWith('image/');
  const isHeicExtSubmit = f.name.toLowerCase().endsWith('.heic') || f.name.toLowerCase().endsWith('.heif');

  if (!isImageMimeSubmit && !isHeicExtSubmit) {
    toast(isHu ? '⚠️ A fájlnak képnek kell lennie.' : '⚠️ Fișierul trebuie să fie o imagine.');
    return;
  }
  if (!document.getElementById('agree').checked) {
    toast(isHu ? '⚠️ Fogadd el a kampányszabályzatot.' : '⚠️ Acceptă regulamentul campaniei.');
    return;
  }

  const btn = this.querySelector('.submit-btn');
  btn.disabled = true;
  btn.textContent = isHu ? '⏳ Küldés...' : '⏳ Se trimite...';
  toast(isHu ? '⏳ A fotó feltöltése folyamatban...' : '⏳ Se încarcă fotografia...');

  try {
    const formData = new FormData();
    let uploadFile = fileIn.files[0];

    const isHeicExt = uploadFile.name.toLowerCase().endsWith('.heic') || uploadFile.name.toLowerCase().endsWith('.heif');
    if (isHeicExt && !uploadFile.type) {
      uploadFile = new File([uploadFile], uploadFile.name, { type: 'image/heic' });
    }

    formData.append('photo',      uploadFile);
    formData.append('email',      email);
    formData.append('nume',       nume);
    formData.append('tel',        tel);
    formData.append('newsletter', newsletter ? 'true' : 'false');

    const data = await new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      xhr.open('POST', 'https://shopify-campaign-app.vercel.app/api/submit');
      xhr.setRequestHeader('x-submit-token', '{{ settings.submit_secret }}');

      xhr.onload = () => {
        try {
          resolve(JSON.parse(xhr.responseText));
        } catch (e) {
          reject(new Error(isHu ? 'Hiba a szerver válaszának olvasásakor.' : 'Eroare la citirea răspunsului de la server.'));
        }
      };
      xhr.onerror = () => {
        reject(new Error(isHu ? 'Hálózati hiba. Kérés blokkolva.' : 'Eroare de rețea. Request blocat.'));
      };

      xhr.send(formData);
    });

    if (!data.success) throw new Error(data.error || (isHu ? 'Ismeretlen hiba.' : 'Eroare necunoscută'));

    document.getElementById('form-wrap').style.display = 'none';
    document.getElementById('success-msg').style.display = 'block';
    document.getElementById('incarca').scrollIntoView({ behavior: 'smooth', block: 'start' });

  } catch(err) {
    console.error(err);
    toast(isHu ? '❌ Hiba a küldés során. Próbáld újra.' : '❌ Eroare la trimitere. Încearcă din nou.');
    btn.disabled = false;
    btn.textContent = isHu ? '🚀 Elküldöm a fotómat' : '🚀 Trimit fotografia mea';
  }
});

/* ── Toast ── */
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

/* ── Feed carousel ── */
(function() {
  const track   = document.getElementById('feedTrack');
  if (!track) return;
  const cards   = Array.from(track.querySelectorAll('.fc'));
  const prevBtn = document.getElementById('feedPrev');
  const nextBtn = document.getElementById('feedNext');

  function getCardWidth() {
    const gap = parseInt(getComputedStyle(track).gap) || 12;
    return cards[0].offsetWidth + gap;
  }
  function getActive() {
    return Math.round(track.scrollLeft / getCardWidth());
  }
  function scrollTo(idx) {
    idx = Math.max(0, Math.min(cards.length - 1, idx));
    track.scrollTo({ left: idx * getCardWidth(), behavior: 'smooth' });
  }

  if (prevBtn) prevBtn.addEventListener('click', () => scrollTo(getActive() - 1));
  if (nextBtn) nextBtn.addEventListener('click', () => scrollTo(getActive() + 1));

  let autoTimer = setInterval(() => scrollTo((getActive() + 1) % cards.length), 3500);
  track.addEventListener('pointerdown', () => { clearInterval(autoTimer); autoTimer = null; });

  let isDown = false, startX, startScroll;
  track.addEventListener('mousedown', e => {
    isDown = true; startX = e.pageX; startScroll = track.scrollLeft;
    track.style.scrollSnapType = 'none';
    if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
  });
  document.addEventListener('mouseup', () => {
    if (!isDown) return; isDown = false;
    track.style.scrollSnapType = 'x mandatory';
    scrollTo(getActive());
  });
  document.addEventListener('mousemove', e => {
    if (!isDown) return; e.preventDefault();
    track.scrollLeft = startScroll - (e.pageX - startX);
  });

  /* ── Random timestamps ── */
  function randMinute() {
    const weights = [10,9,8,7,6,5,4,4,3,3,2,2,2,1,1,1,1,1,1,1];
    const total = weights.reduce((a,b) => a+b, 0);
    let r = Math.random() * total, cum = 0;
    for (let i = 0; i < weights.length; i++) {
      cum += weights[i];
      if (r <= cum) return i * 3 + Math.floor(Math.random() * 3) + 1;
    }
    return Math.floor(Math.random() * 55) + 2;
  }

  const timeEls = track.querySelectorAll('.fc-time');
  const baseMinutes = Array.from({length: 7}, () => randMinute()).sort((a, b) => a - b);

  function fmtTime(m) {
    if (isHu) {
      if (m === 1) return '1 perce';
      if (m < 60)  return m + ' perce';
      const h = Math.floor(m / 60);
      return h + (h === 1 ? ' órája' : ' órája');
    } else {
      if (m === 1) return 'acum 1 minut';
      if (m < 60)  return 'acum ' + m + ' minute';
      const h = Math.floor(m / 60);
      return 'acum ' + h + (h === 1 ? ' oră' : ' ore');
    }
  }

  timeEls.forEach((el, i) => { el.textContent = fmtTime(baseMinutes[i]); });

  setInterval(() => {
    timeEls.forEach((el, i) => {
      baseMinutes[i]++;
      el.textContent = fmtTime(baseMinutes[i]);
    });
  }, 60000);
})();
</script>
