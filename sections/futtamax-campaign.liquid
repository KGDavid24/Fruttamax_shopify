<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600;0,700;0,800;0,900;1,800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

<div id="fruttamax-campaign-wrapper">
<style>
/* ═══════════════════════════════════════════
   TOKENS & SAFE BASE
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper {
  --red:      #d0322b;
  --red-hi:   #ff1616;
  --dark:     #2b2b2b;
  --white:    #ffffff;
  --cream:    #fff8f7;
  --warm:     #FF7D78;
  --red-soft: rgba(208,50,43,0.08);

  font-family: 'Poppins', sans-serif;
  background: var(--white);
  color: var(--dark);
  overflow-x: hidden;
  font-size: 16px;
}

#fruttamax-campaign-wrapper img { 
  max-width: 100%; 
  display: block; 
}

#fruttamax-campaign-wrapper *, 
#fruttamax-campaign-wrapper *::before, 
#fruttamax-campaign-wrapper *::after { 
  box-sizing: border-box; 
}

/* ═══════════════════════════════════════════
   HERO  – mobile first
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #hero {
  background: var(--red);
  padding: 90px 20px 0;
  position: relative; overflow: hidden;
  min-height: 100svh;
  display: flex; flex-direction: column; align-items: center;
}

/* decorative blobs */
#fruttamax-campaign-wrapper .bg-blob { position: absolute; border-radius: 50%; pointer-events: none; }
#fruttamax-campaign-wrapper .bg-blob.b1 { width: 380px; height: 380px; top: -100px; right: -100px; background: rgba(255,255,255,0.07); }
#fruttamax-campaign-wrapper .bg-blob.b2 { width: 180px; height: 180px; bottom: 30%; left: -60px; background: rgba(0,0,0,0.06); }

/* white wave at bottom */
#fruttamax-campaign-wrapper #hero::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0;
  height: 70px;
  background: var(--cream);
  clip-path: ellipse(55% 100% at 50% 100%);
  z-index: 3;
}

/* text block */
#fruttamax-campaign-wrapper .hero-text {
  position: relative; z-index: 2;
  text-align: center;
  max-width: 500px;
  padding-bottom: 24px;
}
#fruttamax-campaign-wrapper .hero-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(255,255,255,0.15);
  border: 1.5px solid rgba(255,255,255,0.3);
  color: #fff; font-size: 11px; font-weight: 700;
  letter-spacing: 1.8px; text-transform: uppercase;
  padding: 6px 14px; border-radius: 50px; margin-bottom: 20px;
}
#fruttamax-campaign-wrapper .hero-h1 {
  font-size: clamp(30px, 8.5vw, 60px);
  font-weight: 900; line-height: 1.08;
  color: #fff; margin-bottom: 18px;
  letter-spacing: -0.5px;
  text-transform: uppercase;
}
#fruttamax-campaign-wrapper .hero-h1 .stroke {
  -webkit-text-stroke: 2px rgba(255,255,255,0.85);
  color: transparent;
  display: block;
}
#fruttamax-campaign-wrapper .hero-h1 .prize {
  display: block;
  font-size: clamp(34px, 9.5vw, 68px);
  line-height: 1.0; margin-top: 2px;
  color: #fff;
  -webkit-text-stroke: 0;
}
#fruttamax-campaign-wrapper .hero-sub {
  font-family: 'Roboto', sans-serif;
  font-size: 15px; color: rgba(255,255,255,0.88);
  line-height: 1.65; margin-bottom: 28px;
}
#fruttamax-campaign-wrapper .hero-sub strong { color: #fff; font-weight: 700; }

/* buttons */
#fruttamax-campaign-wrapper .hero-btns {
  display: flex; flex-direction: column; gap: 12px;
  width: 100%; max-width: 340px; margin: 0 auto 20px;
}
#fruttamax-campaign-wrapper .btn-white {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  background: #fff; color: var(--red);
  font-size: 15px; font-weight: 800;
  padding: 17px 28px; border-radius: 60px;
  text-decoration: none;
  box-shadow: 0 8px 32px rgba(0,0,0,0.22);
  transition: transform .2s, box-shadow .2s;
  width: 100%;
}
#fruttamax-campaign-wrapper .btn-white:hover { transform: translateY(-2px); box-shadow: 0 14px 40px rgba(0,0,0,0.28); }
#fruttamax-campaign-wrapper .btn-ghost {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: transparent; color: #fff;
  font-size: 14px; font-weight: 700;
  padding: 15px 24px; border-radius: 60px;
  text-decoration: none;
  border: 2px solid rgba(255,255,255,0.35);
  transition: border-color .2s, background .2s;
  width: 100%;
}
#fruttamax-campaign-wrapper .btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.1); }

/* pill sticker */
#fruttamax-campaign-wrapper .pill-sticker {
  display: inline-block;
  background: #fff; color: var(--red);
  font-weight: 800; font-size: 13px;
  padding: 8px 18px; border-radius: 50px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.14);
  transform: rotate(-2deg);
  margin-bottom: 20px;
}

/* bottle scene */
#fruttamax-campaign-wrapper .hero-bottles {
  position: relative; z-index: 2;
  width: 100%; max-width: 400px;
  height: 260px;
  display: flex; align-items: flex-end; justify-content: center;
  margin: 0 auto;
  flex-shrink: 0;
}
#fruttamax-campaign-wrapper .bottle {
  position: absolute;
  transition: transform .4s cubic-bezier(.34,1.56,.64,1);
  cursor: pointer;
}
#fruttamax-campaign-wrapper .bottle::after {
  content: '';
  position: absolute; bottom: -6px; left: 50%;
  transform: translateX(-50%);
  width: 55%; height: 14px;
  background: rgba(0,0,0,0.2);
  border-radius: 50%;
  filter: blur(6px);
}
#fruttamax-campaign-wrapper .bt1 { width: 190px; bottom: 30px; left: 50%; transform: translateX(-50%) rotate(-2deg); z-index: 3; }
#fruttamax-campaign-wrapper .bt2 { width: 150px; bottom: 10px; left: 10px; transform: rotate(9deg); z-index: 2; }
#fruttamax-campaign-wrapper .bt3 { width: 150px; bottom: 10px; right: 10px; transform: rotate(-9deg); z-index: 2; }
#fruttamax-campaign-wrapper .bt1:hover { transform: translateX(-50%) rotate(0deg) translateY(-16px); }
#fruttamax-campaign-wrapper .bt2:hover { transform: rotate(0deg) translateY(-16px); }
#fruttamax-campaign-wrapper .bt3:hover { transform: rotate(0deg) translateY(-16px); }

/* floating Gen-Z tags */
#fruttamax-campaign-wrapper .ftag {
  position: absolute;
  background: #fff; color: var(--red);
  font-family: 'Poppins', sans-serif;
  font-weight: 800; font-size: 11px;
  padding: 6px 13px; border-radius: 50px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.16);
  white-space: nowrap; pointer-events: none;
  animation: ftag-bob 3s ease-in-out infinite;
  z-index: 4;
}
#fruttamax-campaign-wrapper .ft1 { top: 16px; left: 2px; transform: rotate(-5deg); animation-delay: 0s; }
#fruttamax-campaign-wrapper .ft2 { top: 30px; right: 0px; transform: rotate(4deg); animation-delay: 1.1s; }

@keyframes ftag-bob {
  0%,100% { translate: 0 0; }
  50%      { translate: 0 -8px; }
}

/* prize strip */
#fruttamax-campaign-wrapper .prize-strip {
  position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  background: var(--dark); color: #fff;
  font-size: 12px; font-weight: 800; letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 10px 24px; border-radius: 14px 14px 0 0;
  white-space: nowrap; z-index: 5;
}
#fruttamax-campaign-wrapper .prize-strip .hi { color: var(--warm); }

/* ═══════════════════════════════════════════
   PRIZES  (new section)
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #premii {
  padding: 72px 20px;
  background: var(--cream);
}
#fruttamax-campaign-wrapper .premii-inner { max-width: 640px; margin: 0 auto; text-align: center; }
#fruttamax-campaign-wrapper .eyebrow {
  font-size: 10px; font-weight: 700; letter-spacing: 3px;
  text-transform: uppercase; color: var(--red); margin-bottom: 8px;
  display: block;
}
#fruttamax-campaign-wrapper .sec-h2 {
  font-size: clamp(28px, 7vw, 52px);
  font-weight: 900; line-height: 1.05;
  color: var(--dark); letter-spacing: -0.5px; margin-bottom: 40px;
}
#fruttamax-campaign-wrapper .sec-h2 .red { color: var(--red); }

#fruttamax-campaign-wrapper .prize-cards {
  display: flex; flex-direction: column; gap: 14px;
  margin-bottom: 32px;
}
#fruttamax-campaign-wrapper .prize-card {
  background: #fff;
  border-radius: 18px; padding: 20px 22px;
  display: flex; align-items: center; gap: 16px;
  text-align: left;
  border: 2px solid #f0e4e3;
  box-shadow: 0 2px 16px rgba(208,50,43,0.06);
  transition: transform .25s, box-shadow .25s;
}
#fruttamax-campaign-wrapper .prize-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(208,50,43,0.12); }
#fruttamax-campaign-wrapper .prize-card.featured {
  border-color: var(--red);
  background: linear-gradient(135deg, #fff 60%, rgba(208,50,43,0.04));
  box-shadow: 0 4px 28px rgba(208,50,43,0.18);
}
#fruttamax-campaign-wrapper .prize-ico { font-size: 36px; flex-shrink: 0; }
#fruttamax-campaign-wrapper .prize-body { flex: 1; }
#fruttamax-campaign-wrapper .prize-title { font-size: 16px; font-weight: 800; color: var(--dark); margin-bottom: 3px; }
#fruttamax-campaign-wrapper .prize-title .amount { color: var(--red); }
#fruttamax-campaign-wrapper .prize-desc { font-family: 'Roboto', sans-serif; font-size: 13px; color: #777; line-height: 1.5; }

/* ═══════════════════════════════════════════
   HOW IT WORKS
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #cum-functioneaza {
  padding: 72px 20px;
  background: var(--white);
}
#fruttamax-campaign-wrapper .sec-inner { max-width: 960px; margin: 0 auto; }

#fruttamax-campaign-wrapper .steps {
  display: flex; flex-direction: column; gap: 20px;
  position: relative;
}
/* vertical connector line */
#fruttamax-campaign-wrapper .steps::before {
  content: '';
  position: absolute; top: 34px; bottom: 34px; left: 33px;
  width: 3px;
  background: repeating-linear-gradient(180deg, var(--red) 0, var(--red) 10px, transparent 10px, transparent 20px);
  z-index: 0;
}
#fruttamax-campaign-wrapper .step {
  display: flex; align-items: flex-start; gap: 20px;
  position: relative; z-index: 1;
  background: #fff; border-radius: 18px;
  padding: 20px 20px;
  border: 2px solid #f5eeed;
  box-shadow: 0 2px 12px rgba(208,50,43,0.05);
  transition: transform .3s, box-shadow .3s;
}
#fruttamax-campaign-wrapper .step:hover { transform: translateX(4px); box-shadow: 0 6px 24px rgba(208,50,43,0.10); }
#fruttamax-campaign-wrapper .step-left { display: flex; flex-direction: column; align-items: center; gap: 6px; flex-shrink: 0; }
#fruttamax-campaign-wrapper .step-num {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--red); color: #fff;
  font-size: 20px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  border: 3px solid var(--white);
  box-shadow: 0 4px 18px rgba(208,50,43,0.38);
  flex-shrink: 0;
}
#fruttamax-campaign-wrapper .step-icon { font-size: 22px; }
#fruttamax-campaign-wrapper .step-body { flex: 1; padding-top: 4px; }
#fruttamax-campaign-wrapper .step-body h3 { font-size: 15px; font-weight: 800; margin-bottom: 5px; color: var(--dark); }
#fruttamax-campaign-wrapper .step-body p {
  font-family: 'Roboto', sans-serif;
  font-size: 13px; color: #777; line-height: 1.6;
}
#fruttamax-campaign-wrapper .step-body strong { color: var(--dark); }

/* ═══════════════════════════════════════════
   NO FRUTTAMAX YET
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #no-frutta {
  padding: 72px 20px;
  background: var(--dark);
  position: relative; overflow: hidden;
}
#fruttamax-campaign-wrapper #no-frutta::before {
  content: '';
  position: absolute; top: -2px; left: 0; right: 0;
  height: 70px;
  background: var(--white);
  clip-path: ellipse(55% 100% at 50% 0%);
}
#fruttamax-campaign-wrapper .no-inner { max-width: 960px; margin: 0 auto; position: relative; z-index: 2; }
#fruttamax-campaign-wrapper .no-inner .eyebrow { color: var(--warm); }
#fruttamax-campaign-wrapper .no-inner .sec-h2 { color: #fff; margin-bottom: 12px; }
#fruttamax-campaign-wrapper .no-sub {
  font-family: 'Roboto', sans-serif;
  font-size: 15px; color: rgba(255,255,255,0.6);
  line-height: 1.7; margin-bottom: 28px;
}
#fruttamax-campaign-wrapper .no-sub strong { color: #fff; }
#fruttamax-campaign-wrapper .no-tagline {
  font-family: 'Poppins', sans-serif;
  font-size: 20px; font-weight: 800;
  color: #fff; line-height: 1.3;
  margin-bottom: 28px;
}
#fruttamax-campaign-wrapper .btn-red {
  display: inline-flex; align-items: center; justify-content: center; gap: 10px;
  background: var(--red); color: #fff;
  font-size: 15px; font-weight: 800;
  padding: 16px 32px; border-radius: 60px;
  text-decoration: none;
  box-shadow: 0 8px 30px rgba(208,50,43,0.5);
  transition: background .2s, transform .2s;
  width: 100%; max-width: 320px;
}
#fruttamax-campaign-wrapper .btn-red:hover { background: var(--red-hi); transform: translateY(-3px); }

/* product shelf – horizontal scroll on mobile */
#fruttamax-campaign-wrapper .shelf-scroll {
  margin-top: 36px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 24px;
}
#fruttamax-campaign-wrapper .shelf-scroll::-webkit-scrollbar { display: none; }
#fruttamax-campaign-wrapper .shelf {
  display: flex; align-items: flex-end;
  gap: 12px;
  width: max-content;
  padding: 12px 4px 0;
}
#fruttamax-campaign-wrapper .sb {
  width: 80px; flex-shrink: 0; position: relative;
  transition: transform .3s cubic-bezier(.34,1.56,.64,1); cursor: pointer;
}
#fruttamax-campaign-wrapper .sb:hover { transform: translateY(-16px) scale(1.08); z-index: 5; }
#fruttamax-campaign-wrapper .sb:nth-child(2):hover { transform: translateY(-16px) scale(1.08); }
#fruttamax-campaign-wrapper .sb:nth-child(4):hover { transform: translateY(-16px) scale(1.08); }
#fruttamax-campaign-wrapper .sb img { width: 100%; height: 110px; object-fit: contain; display: block; }
#fruttamax-campaign-wrapper .sb-inner {
  background: #fff; border-radius: 14px;
  padding: 8px 5px 3px;
  box-shadow: 0 8px 28px rgba(0,0,0,0.38);
  overflow: hidden;
  transition: box-shadow .3s;
}
#fruttamax-campaign-wrapper .sb:hover .sb-inner { box-shadow: 0 18px 44px rgba(0,0,0,0.55); }
#fruttamax-campaign-wrapper .sb .lbl {
  display: block;
  margin-top: 10px;
  font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.45);
  text-align: center; letter-spacing: 0.5px; text-transform: uppercase;
}
#fruttamax-campaign-wrapper .sb a { display: block; text-decoration: none; }

/* ═══════════════════════════════════════════
   UPLOAD FORM
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #incarca {
  padding: 72px 20px;
  background: var(--cream);
  border-top: 4px solid var(--red);
}
#fruttamax-campaign-wrapper .up-inner { max-width: 540px; margin: 0 auto; text-align: center; }
#fruttamax-campaign-wrapper .up-desc {
  font-family: 'Roboto', sans-serif;
  font-size: 15px; color: #666; line-height: 1.65; margin-bottom: 36px;
}

#fruttamax-campaign-wrapper .form-box {
  background: #fff; border-radius: 22px;
  padding: 30px 22px;
  border: 2px solid #f0e4e3;
  box-shadow: 0 4px 32px rgba(208,50,43,0.07);
  text-align: left;
}
#fruttamax-campaign-wrapper .fg { margin-bottom: 16px; }
#fruttamax-campaign-wrapper .fg label {
  font-family: 'Poppins', sans-serif;
  display: block; font-size: 12px; font-weight: 700;
  color: var(--dark); margin-bottom: 6px; letter-spacing: 0.2px;
}
#fruttamax-campaign-wrapper .fg label .req { color: var(--red); }
#fruttamax-campaign-wrapper .fg input {
  width: 100%; padding: 14px 16px;
  border: 2px solid #e8dede; border-radius: 12px;
  font-size: 16px; /* 16px prevents iOS zoom */
  font-family: 'Roboto', sans-serif;
  color: var(--dark); background: #fff; outline: none;
  transition: border-color .2s, box-shadow .2s;
  -webkit-appearance: none; appearance: none;
}
#fruttamax-campaign-wrapper .fg input:focus { border-color: var(--red); box-shadow: 0 0 0 4px rgba(208,50,43,0.09); }

/* Drop zone */
#fruttamax-campaign-wrapper .dz {
  border: 3px dashed #ddd; border-radius: 16px;
  padding: 32px 20px; text-align: center;
  background: var(--cream); cursor: pointer; position: relative;
  transition: border-color .2s, background .2s;
}
#fruttamax-campaign-wrapper .dz.over { border-color: var(--red); background: rgba(208,50,43,0.03); }
#fruttamax-campaign-wrapper .dz input[type="file"] {
  position: absolute; inset: 0; opacity: 0;
  cursor: pointer; width: 100%; height: 100%;
}
#fruttamax-campaign-wrapper .dz-ico  { font-size: 38px; display: block; margin-bottom: 10px; }
#fruttamax-campaign-wrapper .dz-main { font-size: 14px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
#fruttamax-campaign-wrapper .dz-hint { font-size: 12px; color: #aaa; font-family: 'Roboto', sans-serif; }
#fruttamax-campaign-wrapper .dz-lim  {
  display: inline-block; margin-top: 10px;
  font-size: 11px; font-weight: 700; color: var(--red);
  background: rgba(208,50,43,0.08);
  padding: 4px 12px; border-radius: 50px;
}
#fruttamax-campaign-wrapper #prev-wrap {
  display: none; margin-top: 14px;
  align-items: center; gap: 12px;
  background: #fff; border-radius: 12px;
  padding: 12px 16px; border: 2px solid var(--red);
}
#fruttamax-campaign-wrapper #prev-wrap img { width: 52px; height: 52px; object-fit: cover; border-radius: 8px; }
#fruttamax-campaign-wrapper .pi { flex: 1; text-align: left; }
#fruttamax-campaign-wrapper .pi-name { font-size: 13px; font-weight: 700; color: var(--dark); }
#fruttamax-campaign-wrapper .pi-size { font-size: 12px; color: #aaa; margin-top: 2px; font-family: 'Roboto', sans-serif; }
#fruttamax-campaign-wrapper #rm-btn {
  background: none; border: none; cursor: pointer;
  font-size: 20px; color: #ccc; transition: color .2s;
  min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center;
}
#fruttamax-campaign-wrapper #rm-btn:hover { color: var(--red); }

/* agree */
#fruttamax-campaign-wrapper .agree {
  display: flex; align-items: flex-start; gap: 12px;
  margin: 18px 0 22px;
}
#fruttamax-campaign-wrapper .agree input[type="checkbox"] {
  width: 22px; height: 22px; min-width: 22px;
  accent-color: var(--red); margin-top: 2px; cursor: pointer;
}
#fruttamax-campaign-wrapper .agree label {
  font-family: 'Roboto', sans-serif;
  font-size: 13px; color: #666; line-height: 1.55; cursor: pointer;
}
#fruttamax-campaign-wrapper .agree label a { color: var(--red); }

#fruttamax-campaign-wrapper .submit-btn {
  width: 100%; background: var(--red); color: #fff;
  border: none; padding: 18px;
  border-radius: 60px; font-size: 16px; font-weight: 800;
  font-family: 'Poppins', sans-serif;
  cursor: pointer; letter-spacing: 0.3px;
  box-shadow: 0 8px 28px rgba(208,50,43,0.4);
  transition: background .2s, transform .2s, box-shadow .2s;
  min-height: 56px;
  -webkit-appearance: none; appearance: none;
}
#fruttamax-campaign-wrapper .submit-btn:hover { background: var(--red-hi); transform: translateY(-2px); box-shadow: 0 14px 40px rgba(208,50,43,0.48); }
#fruttamax-campaign-wrapper .submit-btn:disabled { opacity: 0.6; transform: none; cursor: not-allowed; }

/* Success */
#fruttamax-campaign-wrapper #success-msg { display: none; text-align: center; padding: 48px 16px; }
#fruttamax-campaign-wrapper #success-msg .big-em { font-size: 68px; display: block; margin-bottom: 16px; }
#fruttamax-campaign-wrapper #success-msg h2 {
  font-family: 'Poppins', sans-serif;
  font-size: clamp(32px, 8vw, 48px); font-weight: 900; color: var(--red);
  letter-spacing: -0.5px; margin-bottom: 12px;
}
#fruttamax-campaign-wrapper #success-msg p {
  font-family: 'Roboto', sans-serif;
  font-size: 15px; color: #666; line-height: 1.65;
}

/* ═══════════════════════════════════════════
   TOAST
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #toast {
  position: fixed; bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(90px);
  background: var(--dark); color: #fff;
  padding: 13px 26px; border-radius: 60px;
  font-size: 14px; font-weight: 700;
  z-index: 9999; transition: transform .3s ease;
  white-space: nowrap; pointer-events: none;
  max-width: calc(100vw - 40px); text-align: center;
  box-shadow: 0 8px 28px rgba(0,0,0,0.3);
}
#fruttamax-campaign-wrapper #toast.show { transform: translateX(-50%) translateY(0); }

/* ═══════════════════════════════════════════
   REVEAL ANIMATION
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper .reveal {
  opacity: 0; transform: translateY(24px);
  transition: opacity .5s ease, transform .5s ease;
}
#fruttamax-campaign-wrapper .reveal.vis { opacity: 1; transform: none; }

/* ═══════════════════════════════════════════
   TABLET  ≥ 640px
═══════════════════════════════════════════ */
@media (min-width: 640px) {
  #fruttamax-campaign-wrapper #hero { padding: 100px 32px 0; }
  #fruttamax-campaign-wrapper .hero-text { padding-bottom: 30px; }

  #fruttamax-campaign-wrapper .hero-btns { flex-direction: row; justify-content: center; max-width: 100%; }
  #fruttamax-campaign-wrapper .btn-white, #fruttamax-campaign-wrapper .btn-ghost { width: auto; }

