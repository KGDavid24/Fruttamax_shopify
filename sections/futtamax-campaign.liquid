  #fruttamax-campaign-wrapper .bt1 { width: 230px; bottom: 35px; }
  #fruttamax-campaign-wrapper .bt2, #fruttamax-campaign-wrapper .bt3 { width: 185px; }

  #fruttamax-campaign-wrapper .prize-cards { flex-direction: row; flex-wrap: wrap; }
  #fruttamax-campaign-wrapper .prize-card { flex: 1 1 calc(50% - 8px); min-width: 220px; }

  #fruttamax-campaign-wrapper .steps { flex-direction: row; flex-wrap: wrap; gap: 16px; }
  #fruttamax-campaign-wrapper .steps::before { display: none; }
  #fruttamax-campaign-wrapper .step { flex: 1 1 calc(50% - 8px); flex-direction: column; align-items: center; text-align: center; gap: 10px; }
  #fruttamax-campaign-wrapper .step-body { padding-top: 0; }
  #fruttamax-campaign-wrapper .step-left { flex-direction: row; justify-content: center; }

  #fruttamax-campaign-wrapper #no-frutta { padding: 90px 32px; }
  #fruttamax-campaign-wrapper .btn-red { width: auto; }
  #fruttamax-campaign-wrapper .shelf-scroll { overflow-x: visible; }
  #fruttamax-campaign-wrapper .shelf { width: auto; justify-content: center; }
  #fruttamax-campaign-wrapper .sb { width: 90px; }
  #fruttamax-campaign-wrapper .sb:nth-child(2), #fruttamax-campaign-wrapper .sb:nth-child(4) { transform: none; }

  #fruttamax-campaign-wrapper .form-box { padding: 40px 36px; }
}

/* ═══════════════════════════════════════════
   DESKTOP  ≥ 1024px
═══════════════════════════════════════════ */
@media (min-width: 1024px) {
  #fruttamax-campaign-wrapper #hero {
    overflow: hidden;
    flex-direction: column;
    align-items: center;
    padding: 130px 48px 0;
    min-height: 100vh;
  }
  #fruttamax-campaign-wrapper #hero::after { height: 110px; }

  #fruttamax-campaign-wrapper .hero-text {
    text-align: center;
    max-width: 780px;
    padding-bottom: 36px;
    padding-right: 0;
  }
  #fruttamax-campaign-wrapper .hero-h1 {
    font-size: 72px;
    margin-bottom: 24px;
  }
  #fruttamax-campaign-wrapper .hero-h1 .stroke { display: inline; }
  #fruttamax-campaign-wrapper .hero-h1 .prize {
    display: block; font-size: 72px; margin-top: 4px;
  }
  #fruttamax-campaign-wrapper .hero-h1 .prize br { display: none; }

  #fruttamax-campaign-wrapper .hero-badge  { margin-bottom: 22px; }
  #fruttamax-campaign-wrapper .hero-sub    { font-size: 17px; max-width: 560px; margin: 0 auto 32px; }
  #fruttamax-campaign-wrapper .hero-btns   {
    flex-direction: row; justify-content: center;
    margin: 0 auto 20px; max-width: none; width: auto; gap: 14px;
  }
  #fruttamax-campaign-wrapper .btn-white   { width: auto; white-space: nowrap; }
  #fruttamax-campaign-wrapper .btn-ghost   { width: auto; white-space: nowrap; }
  #fruttamax-campaign-wrapper .pill-sticker { display: inline-block; }

  #fruttamax-campaign-wrapper .hero-bottles {
    position: relative; display: flex; flex-direction: row;
    align-items: flex-end; justify-content: center; gap: 56px;
    width: 100%; max-width: 860px; height: 400px;
    overflow: visible; margin-top: -20px;
  }
  #fruttamax-campaign-wrapper .bottle { position: relative; bottom: auto; left: auto; right: auto; }
  #fruttamax-campaign-wrapper .bt1 { width: 300px; transform: rotate(-2deg); order: 2; }
  #fruttamax-campaign-wrapper .bt2 { width: 230px; transform: rotate(6deg); margin-bottom: 10px; order: 1; }
  #fruttamax-campaign-wrapper .bt3 { width: 230px; transform: rotate(-8deg); margin-bottom: 6px; order: 3; }
  #fruttamax-campaign-wrapper .bt1:hover { transform: rotate(0deg) translateY(-18px); }
  #fruttamax-campaign-wrapper .bt2:hover { transform: rotate(0deg) translateY(-18px); }
  #fruttamax-campaign-wrapper .bt3:hover { transform: rotate(0deg) translateY(-18px); }
  #fruttamax-campaign-wrapper .bottle::after { display: none; }

  #fruttamax-campaign-wrapper .ftag { font-size: 12px; padding: 8px 16px; }
  #fruttamax-campaign-wrapper .ft1  { position: absolute; bottom: auto; top: 12%; left: -110px; transform: rotate(-5deg); animation-delay: 0s; }
  #fruttamax-campaign-wrapper .ft2  { position: absolute; bottom: auto; top: 18%; right: -110px; transform: rotate(4deg); animation-delay: 1.1s; }

  #fruttamax-campaign-wrapper .prize-strip { position: absolute; bottom: 0; }
  #fruttamax-campaign-wrapper .prize-card { flex: 1 1 calc(25% - 12px); }

  #fruttamax-campaign-wrapper #premii { padding: 110px 56px; }
  #fruttamax-campaign-wrapper #cum-functioneaza { padding: 110px 56px; }
  #fruttamax-campaign-wrapper .steps { flex-direction: row; flex-wrap: nowrap; gap: 12px; position: relative; }
  #fruttamax-campaign-wrapper .steps::before {
    display: block; content: ''; position: absolute;
    top: 22px; left: calc(12.5% + 4px); right: calc(12.5% + 4px);
    height: 3px; width: auto; bottom: auto;
    background: repeating-linear-gradient(90deg, var(--red) 0, var(--red) 10px, transparent 10px, transparent 20px);
  }
  #fruttamax-campaign-wrapper .step { flex: 1; flex-direction: column; align-items: center; text-align: center; }
  #fruttamax-campaign-wrapper .step-left { flex-direction: column; align-items: center; }

  #fruttamax-campaign-wrapper #no-frutta { padding: 110px 56px; }
  #fruttamax-campaign-wrapper .no-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  #fruttamax-campaign-wrapper .shelf-scroll { margin-top: 0; }
  #fruttamax-campaign-wrapper .shelf { align-items: flex-end; justify-content: flex-start; }
  #fruttamax-campaign-wrapper .sb { width: 100px; }
  #fruttamax-campaign-wrapper .sb:nth-child(2), #fruttamax-campaign-wrapper .sb:nth-child(4) { transform: none; margin-bottom: 0; }
  #fruttamax-campaign-wrapper .sb:nth-child(2):hover, #fruttamax-campaign-wrapper .sb:nth-child(4):hover { transform: translateY(-16px) scale(1.08); }

  #fruttamax-campaign-wrapper #incarca { padding: 110px 56px; }
  #fruttamax-campaign-wrapper #incarca .sec-h2 { white-space: nowrap; }
  #fruttamax-campaign-wrapper .up-desc {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
}

/* ═══════════════════════════════════════════
   SOCIAL PROOF FEED
═══════════════════════════════════════════ */
#fruttamax-campaign-wrapper #feed {
  padding: 72px 0 60px;
  background: var(--white);
  overflow: hidden;
}
#fruttamax-campaign-wrapper .feed-header {
  padding: 0 20px 28px;
  max-width: 960px; margin: 0 auto;
}
#fruttamax-campaign-wrapper .feed-live {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(208,50,43,0.08);
  border-radius: 50px; padding: 6px 14px; margin-bottom: 10px;
}
#fruttamax-campaign-wrapper .feed-dot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--red);
  animation: pulse-dot 1.4s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0.4; transform:scale(0.7); }
}
#fruttamax-campaign-wrapper .feed-live-txt {
  font-size: 11px; font-weight: 700; color: var(--red);
  letter-spacing: 1.5px; text-transform: uppercase;
}

#fruttamax-campaign-wrapper .feed-outer { position: relative; }
#fruttamax-campaign-wrapper .feed-track {
  display: flex; gap: 12px;
  overflow-x: auto; scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
  padding: 16px 20px 28px;
  cursor: grab; align-items: flex-end;
}
#fruttamax-campaign-wrapper .feed-track:active { cursor: grabbing; }
#fruttamax-campaign-wrapper .feed-track::-webkit-scrollbar { display: none; }

#fruttamax-campaign-wrapper .fc {
  flex-shrink: 0; background: #fff; border-radius: 4px;
  box-shadow: 0 6px 28px rgba(0,0,0,0.13), 0 1px 4px rgba(0,0,0,0.08);
  scroll-snap-align: start;
  transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s;
  overflow: visible; position: relative;
}
#fruttamax-campaign-wrapper .fc:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.10); z-index: 5; }

#fruttamax-campaign-wrapper .fc:nth-child(1)  { transform: rotate(-2.8deg); }
#fruttamax-campaign-wrapper .fc:nth-child(1):hover { transform: rotate(-1deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(2)  { transform: rotate(1.5deg); margin-bottom: 20px; }
#fruttamax-campaign-wrapper .fc:nth-child(2):hover { transform: rotate(0.5deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(3)  { transform: rotate(-1.2deg); margin-bottom: 8px; }
#fruttamax-campaign-wrapper .fc:nth-child(3):hover { transform: rotate(0deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(4)  { transform: rotate(3deg); margin-bottom: 24px; }
#fruttamax-campaign-wrapper .fc:nth-child(4):hover { transform: rotate(1.5deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(5)  { transform: rotate(-2.2deg); margin-bottom: 4px; }
#fruttamax-campaign-wrapper .fc:nth-child(5):hover { transform: rotate(-0.8deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(6)  { transform: rotate(1.8deg); margin-bottom: 16px; }
#fruttamax-campaign-wrapper .fc:nth-child(6):hover { transform: rotate(0.5deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(7)  { transform: rotate(-0.8deg); margin-bottom: 10px; }
#fruttamax-campaign-wrapper .fc:nth-child(7):hover { transform: rotate(0deg) translateY(-8px); }
#fruttamax-campaign-wrapper .fc:nth-child(8)  { transform: rotate(2.5deg); margin-bottom: 18px; }
#fruttamax-campaign-wrapper .fc:nth-child(8):hover { transform: rotate(1deg) translateY(-8px); }

#fruttamax-campaign-wrapper .fc-photo-wrap { padding: 8px 8px 0; }
#fruttamax-campaign-wrapper .fc-photo { display: block; border-radius: 2px; object-fit: cover; background: #eee; }
#fruttamax-campaign-wrapper .fc:nth-child(odd)  .fc-photo { width: 200px; height: 265px; }
#fruttamax-campaign-wrapper .fc:nth-child(even) .fc-photo { width: 186px; height: 248px; }
#fruttamax-campaign-wrapper .fc:nth-child(3)    .fc-photo { width: 214px; height: 280px; }
#fruttamax-campaign-wrapper .fc:nth-child(6)    .fc-photo { width: 192px; height: 254px; }

#fruttamax-campaign-wrapper .fc-body { padding: 10px 10px 12px; }
#fruttamax-campaign-wrapper .fc-user { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
#fruttamax-campaign-wrapper .fc-avatar {
  width: 26px; height: 26px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: #fff; flex-shrink: 0;
}
#fruttamax-campaign-wrapper .fc-meta { flex: 1; min-width: 0; }
#fruttamax-campaign-wrapper .fc-handle { font-size: 11px; font-weight: 800; color: var(--dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
#fruttamax-campaign-wrapper .fc-time { font-size: 10px; color: #bbb; font-family: 'Roboto', sans-serif; margin-top: 1px; }
#fruttamax-campaign-wrapper .fc-caption { font-family: 'Roboto', sans-serif; font-size: 11.5px; color: #555; line-height: 1.5; }
#fruttamax-campaign-wrapper .fc-loc { font-size: 10px; color: #bbb; margin-top: 5px; font-family: 'Roboto', sans-serif; display: flex; align-items: center; gap: 3px; }

#fruttamax-campaign-wrapper .feed-arrow {
  display: none; position: absolute; top: 50%; transform: translateY(-50%);
  width: 44px; height: 44px; border-radius: 50%; background: #fff; border: 2px solid #eee;
  box-shadow: 0 4px 16px rgba(0,0,0,0.12); cursor: pointer; align-items: center; justify-content: center;
  font-size: 20px; z-index: 10; transition: background .2s, box-shadow .2s;
}
#fruttamax-campaign-wrapper .feed-arrow:hover { background: var(--cream); box-shadow: 0 6px 24px rgba(0,0,0,0.18); }
#fruttamax-campaign-wrapper .feed-arrow.prev { left: 12px; }
#fruttamax-campaign-wrapper .feed-arrow.next { right: 12px; }

@media (min-width: 640px) {
  #fruttamax-campaign-wrapper .feed-track { padding: 20px 32px 32px; gap: 16px; }
  #fruttamax-campaign-wrapper .fc:nth-child(odd)  .fc-photo { width: 220px; height: 292px; }
  #fruttamax-campaign-wrapper .fc:nth-child(even) .fc-photo { width: 200px; height: 266px; }
  #fruttamax-campaign-wrapper .fc:nth-child(3)    .fc-photo { width: 236px; height: 312px; }
  #fruttamax-campaign-wrapper .fc:nth-child(6)    .fc-photo { width: 208px; height: 276px; }
}
@media (min-width: 1024px) {
  #fruttamax-campaign-wrapper #feed { padding: 110px 0 80px; }
  #fruttamax-campaign-wrapper .feed-header { padding: 0 56px 44px; }

  #fruttamax-campaign-wrapper .feed-outer { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  #fruttamax-campaign-wrapper .feed-track {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 24px;
    overflow-x: visible; scroll-snap-type: none; cursor: default;
    padding: 40px 0 48px; align-items: flex-end;
  }
  #fruttamax-campaign-wrapper .feed-track:active { cursor: default; }
  #fruttamax-campaign-wrapper .fc { flex: 0 0 240px; scroll-snap-align: none; }

  #fruttamax-campaign-wrapper .fc:nth-child(1) { margin-top: 40px; }
  #fruttamax-campaign-wrapper .fc:nth-child(2) { margin-top: 0; }
  #fruttamax-campaign-wrapper .fc:nth-child(3) { margin-top: 60px; }
  #fruttamax-campaign-wrapper .fc:nth-child(4) { margin-top: 16px; }
  #fruttamax-campaign-wrapper .fc:nth-child(5) { margin-top: 24px; }
  #fruttamax-campaign-wrapper .fc:nth-child(6) { margin-top: 64px; }
  #fruttamax-campaign-wrapper .fc:nth-child(7) { margin-top: 8px; }
  #fruttamax-campaign-wrapper .fc:nth-child(8) { margin-top: 48px; }

  #fruttamax-campaign-wrapper .fc-photo-wrap { padding: 10px 10px 0; }
  #fruttamax-campaign-wrapper .fc .fc-photo        { width: 100% !important; height: 260px !important; }
  #fruttamax-campaign-wrapper .fc:nth-child(3) .fc-photo { height: 290px !important; }
  #fruttamax-campaign-wrapper .fc:nth-child(6) .fc-photo { height: 270px !important; }
  #fruttamax-campaign-wrapper .fc-body { padding: 12px 12px 14px; }

  #fruttamax-campaign-wrapper .feed-arrow { display: none; }
  #fruttamax-campaign-wrapper .feed-dots  { display: none; }
}
</style>

{%- assign is_hu = false -%}
{%- if request.locale.iso_code == 'hu' -%}
  {%- assign is_hu = true -%}
{%- endif -%}

<section id="hero">
  <div class="bg-blob b1"></div>
  <div class="bg-blob b2"></div>

  <div class="hero-text reveal">
    <div class="hero-badge">
      {%- if is_hu -%}
        🇷🇴 A FruttaMax megérkezett Romániába!
      {%- else -%}
        🇷🇴 FruttaMax a ajuns în România!
      {%- endif -%}
    </div>
    <h1 class="hero-h1">
      {%- if is_hu -%}
        HOL NINCS
        <span class="stroke">FRUTTAMAX?</span>
        <span class="prize">NYERJ <br>10.000 LEJT.</span>
      {%- else -%}
        UNDE NU E
        <span class="stroke">FRUTTAMAX?</span>
        <span class="prize">CÂȘTIGĂ <br>10.000 LEI.</span>
      {%- endif -%}
    </h1>
    <p class="hero-sub">
      {%- if is_hu -%}
        Fotózd le az üveget a legrandomabb, legabszurdabb helyzetben. Töltsd fel a képet. Nyerd meg a főnyereményt.
      {%- else -%}
        Fotografiază sticla în cel mai <strong>random, nepotrivit, absurd</strong> context posibil. Încarcă poza. Câștigă marele premiu.
      {%- endif -%}
    </p>
    <div class="hero-btns">
      {%- if is_hu -%}
        <a href="#incarca" class="btn-white">📸 Feltöltöm a képemet</a>
        <a href="#cum-functioneaza" class="btn-ghost">Hogy működik?</a>
      {%- else -%}
        <a href="#incarca" class="btn-white">📸 Încarc fotografia mea</a>
        <a href="#cum-functioneaza" class="btn-ghost">Cum funcționează?</a>
      {%- endif -%}
    </div>
    <div class="pill-sticker">
      {%- if is_hu -%}
        🏆 Főnyeremény: 10.000 LEJ készpénz
      {%- else -%}
        🏆 Grand Prize: 10.000 LEI cash
      {%- endif -%}
    </div>
  </div>

  <div class="hero-bottles">
    {%- if is_hu -%}
      <div class="ftag ft1">a zuhanyban??? 💀</div>
      <div class="ftag ft2">teljesen random ✨</div>
    {%- else -%}
      <div class="ftag ft1">în duș??? 💀</div>
      <div class="ftag ft2">random af ✨</div>
    {%- endif -%}

    <div class="bottle bt2">
      <img src="https://fruttamax.ro/cdn/shop/files/raspberry2.avif"
           alt="{%- if is_hu -%}Málna ízű FruttaMax{%- else -%}Zmeură{%- endif -%}"
           loading="lazy">
    </div>
    <div class="bottle bt3">
      <img src="https://fruttamax.ro/cdn/shop/files/lemon-lime2.avif"
           alt="{%- if is_hu -%}Citrom-Lime ízű FruttaMax{%- else -%}Lămâie Lime{%- endif -%}"
           loading="lazy">
    </div>
    <div class="bottle bt1">
      <img src="https://fruttamax.ro/cdn/shop/files/strawberry2.avif"
           alt="{%- if is_hu -%}Eper ízű FruttaMax{%- else -%}Căpșuni{%- endif -%}"
           loading="lazy">
    </div>

    <div class="prize-strip">
      {%- if is_hu -%}
        FŐNYEREMÉNY: <span class="hi">10.000 LEJ</span> 🎉
      {%- else -%}
        MARELE PREMIU: <span class="hi">10.000 LEI</span> 🎉
      {%- endif -%}
    </div>
  </div>
</section>

<section id="premii">
  <div class="premii-inner">
    <span class="eyebrow reveal">
      {%- if is_hu -%}Mit nyerhetsz{%- else -%}Ce poți câștiga{%- endif -%}
    </span>
    <h2 class="sec-h2 reveal">
      {%- if is_hu -%}
        Valódi <span class="red">nyeremények.</span>
      {%- else -%}
        Premii <span class="red">reale.</span>
      {%- endif -%}
    </h2>
    <div class="prize-cards">

      <div class="prize-card featured reveal" style="transition-delay:.05s">
        <div class="prize-ico">💸</div>
        <div class="prize-body">
          <div class="prize-title">
            {%- if is_hu -%}
              Főnyeremény: <span class="amount">10.000 lej</span>
            {%- else -%}
              Marele Premiu: <span class="amount">10.000 lei</span>
            {%- endif -%}
          </div>
          <div class="prize-desc">
            {%- if is_hu -%}
              Egyetlen győztes, e-mailben értesítve. A legrandomabb kép nyer.
            {%- else -%}
              Un singur câștigător, anunțat pe email. Cea mai random poză câștigă.
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="prize-card reveal" style="transition-delay:.1s">
        <div class="prize-ico">🏆</div>
        <div class="prize-body">
          <div class="prize-title">
            {%- if is_hu -%}Top 10 nyertes{%- else -%}Top 10 câștigă{%- endif -%}
          </div>
          <div class="prize-desc">
            {%- if is_hu -%}
              A legjobb 10 kép mindegyike értékes meglepetés-nyereményt kap.
            {%- else -%}
              Cele mai creative 10 poze câștigă fiecare un premiu surpriză de valoare.
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="prize-card reveal" style="transition-delay:.15s">
        <div class="prize-ico">🎁</div>
        <div class="prize-body">
          <div class="prize-title">
            {%- if is_hu -%}Azonnali 20%{%- else -%}20% instant{%- endif -%}
          </div>
          <div class="prize-desc">
            {%- if is_hu -%}
              Azonnali 20% kedvezményt kapsz — csak azért, mert részt vettél.
            {%- else -%}
              Primești o reducere de 20% instant. Doar pentru că ai participat.
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="prize-card reveal" style="transition-delay:.2s">
        <div class="prize-ico">📲</div>
        <div class="prize-body">
          <div class="prize-title">
            {%- if is_hu -%}
              Felkerülsz a <span style="color:var(--red)">@fruttamax.ro</span> oldalra
            {%- else -%}
              Ajungi pe <span style="color:var(--red)">@fruttamax.ro</span>
            {%- endif -%}
          </div>
          <div class="prize-desc">
            {%- if is_hu -%}
              Tedd ki a képet Story-ban, jelöld meg a <strong style="color:var(--dark)">@fruttamax.ro</strong> oldalt, és mi repostoljuk.
            {%- else -%}
              Postează poza în Story, dă tag la <strong style="color:var(--dark)">@fruttamax.ro</strong> și îți repostăm poza.
            {%- endif -%}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<section id="feed">
  <div class="feed-header">
    <div class="feed-live reveal">
