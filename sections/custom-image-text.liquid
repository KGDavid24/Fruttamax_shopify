{%- style -%}
  /* KÜLSŐ SÁV */
  .section-clean-wrapper-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    background-color: {{ section.settings.bg_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  /* 1200PX KONTÉNER */
  .clean-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    
    display: flex;
    /* FONTOS: Mostantól középre igazítunk függőlegesen, mert a képnek fix magassága lesz */
    align-items: center; 
    justify-content: space-between;
    gap: 60px;
  }

  /* KÉP OSZLOP */
  .clean-image-col {
    position: relative;
    display: block;
    width: 100%;
    /* DESKTOP MAGASSÁG BEÁLLÍTÁSA */
    height: {{ section.settings.desktop_image_height }}px;
    overflow: hidden;
    border-radius: 20px; /* Lekerekítés a dobozon */
  }

  .clean-image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Kitölti a keretet torzítás nélkül */
    display: block;
  }

  /* SZÖVEG OSZLOP */
  .clean-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center; 
    align-items: flex-start;
    text-align: left;
    padding: 20px 0; 
    flex: 1; 
  }

  /* DESKTOP MÉRETEZÉS (Szélesség) */
  @media screen and (min-width: 900px) {
    .clean-image-col {
      /* A beállított %-ot kapja meg a kép oszlop szélessége */
      flex: 0 0 {{ section.settings.desktop_image_width }}%;
      max-width: {{ section.settings.desktop_image_width }}%;
    }
  }

  /* IGAZÍTÁS BEÁLLÍTÁSOK */
  .clean-text-col.text-center { align-items: center; text-align: center; }
  .clean-text-col.text-right { align-items: flex-end; text-align: right; }

  /* TYPOGRAPHY */
  .clean-heading {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    color: {{ section.settings.heading_color }};
    font-family: inherit;
  }

  .clean-subheading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 15px;
    color: {{ section.settings.subheading_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-family: inherit;
  }

  .clean-text {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 35px;
    color: {{ section.settings.text_color }};
    font-family: inherit;
  }

  /* GOMB */
  .clean-btn {
    display: inline-block;
    padding: 15px 45px;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .clean-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1); 
    opacity: 0.9;
  }

  /* MOBIL NÉZET */
  @media screen and (max-width: 900px) {
    .clean-container {
      flex-direction: column;
      gap: 30px;
      align-items: center;
    }

    .clean-image-col {
      /* MOBIL MAGASSÁG BEÁLLÍTÁSA */
      height: {{ section.settings.mobile_image_height }}px;
      flex: 0 0 100%;
      max-width: 100%;
    }

    .clean-text-col {
      padding: 0;
      align-items: center !important;
      text-align: center !important;
    }

    .clean-heading { font-size: 2rem; }
  }
{%- endstyle -%}

<div class="section-clean-wrapper-{{ section.id }}">
  <div class="clean-container">
    
    <div class="clean-image-col" style="order: {% if section.settings.image_position == 'left' %}1{% else %}2{% endif %};">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="clean-text-col text-{{ section.settings.text_align }}" style="order: {% if section.settings.image_position == 'left' %}2{% else %}1{% endif %};">
      
      {%- if section.settings.subheading != blank -%}
        <div class="clean-subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="clean-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="clean-text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link }}" class="clean-btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Kép + Szöveg",
  "settings": [
    {
      "type": "header",
      "content": "Kép Méretezése"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Kép Feltöltése"
    },
    {
      "type": "range",
      "id": "desktop_image_width",
      "min": 20,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Kép Szélessége (Desktop)",
      "default": 50
    },
    {
      "type": "range",
      "id": "desktop_image_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Kép Magassága (Desktop)",
      "default": 500,
      "info": "Állítsd be, milyen magas legyen a kép pixelben."
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Kép Magassága (Mobil)",
      "default": 350
    },
    {
      "type": "header",
      "content": "Elrendezés"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Kép Pozíciója",
      "options": [
        { "value": "left", "label": "Bal oldalon" },
        { "value": "right", "label": "Jobb oldalon" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Tartalom (Română)"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Alcím (Kicsi)",
      "default": "INOVAȚIE ȘI TRADIȚIE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Főcím",
      "default": "Siropuri create cu pasiune"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Szöveg",
      "default": "Descoperă noua generație de siropuri FruttaMax, unde gustul autentic de fructe se întâlnește cu grija pentru sănătate. Produsele noastre conțin 50-60% fructe și sunt îndulcite cu stevia, oferind o experiență răcoritoare fără compromisuri."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Gomb Szöveg",
      "default": "Vezi Colecția"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Gomb Link"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Szöveg Igazítása",
      "options": [
        { "value": "left", "label": "Balra" },
        { "value": "center", "label": "Középre" },
        { "value": "right", "label": "Jobbra" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Színek"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Szekció Háttérszíne",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Címsor Színe",
      "default": "#E80404"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Alcím Színe",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Szöveg Színe",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Gomb Háttérszíne",
      "default": "#E80404"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Gomb Szöveg Színe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Felül",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Alul",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Kép + Szöveg (Full Control)"
    }
  ]
}
{% endschema %}