{%- style -%}
  /* FŐ KONTÉNER */
  .section-{{ section.id }}-root {
    position: relative;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    /* Mobilon nagy alsó helyet hagyunk az abszolút képnek: */
    padding-bottom: 400px; 
    overflow: hidden;
    font-family: 'Helvetica', 'Arial', sans-serif;
    display: flex;
    flex-direction: column;
    justify-content: flex-start; 
    
    /* ÚJ: Alacsony szintű réteg, hogy ne zavarja a menüt */
    z-index: 0; 
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-root {
      /* Desktopon nem kell akkora padding, mert egymás mellett vannak */
      padding-bottom: 0; 
      min-height: 700px;
      justify-content: center; /* Szöveg vertikálisan középre */
    }
  }

  /* HULLÁM HÁTTÉR (Legalul) */
  .custom-wave-bg {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    
    /* JAVÍTVA: 1-ről 0-ra, hogy legalul legyen */
    z-index: 0; 
    
    line-height: 0;
    pointer-events: none;
  }

  .custom-wave-bg svg {
    display: block;
    width: 100%;
    height: 140px; /* Mobil hullám */
    fill: {{ section.settings.brand_color }};
  }

  @media screen and (min-width: 990px) {
    .custom-wave-bg svg {
      height: 350px; /* Desktop hullám */
    }
  }

  /* TARTALOM KONTÉNER (Szélesség korlát) */
  .custom-content-wrapper {
    position: relative; /* Fontos a belső abszolút elemekhez */
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 20px;
    
    /* JAVÍTVA: 10-ről 2-re csökkentve, hogy a menü alatt maradjon */
    z-index: 2;
    
    height: 100%;
    /* Flexbox csak a desktop elrendezéshez kell */
  }

  /* SZÖVEGES RÉSZ */
  .custom-text-side {
    position: relative;
    
    /* JAVÍTVA: 10-ről 2-re csökkentve */
    z-index: 2;
    
    width: 100%;
    text-align: center;
    /* Mobilon semmi extra, marad a folyamban */
  }

  /* --- KÉP KONTÉNER (A MEGOLDÁS) --- */
  .custom-image-wrapper {
    /* ABSZOLÚT POZÍCIÓ MINDEN ESZKÖZÖN! */
    position: absolute;
    bottom: 0; /* Rászögezzük az aljára */
    left: 50%; /* Mobilon középre igazítás kezdete */
    transform: translateX(-50%); /* Mobilon középre húzás */
    
    /* JAVÍTVA: 5-ről 1-re csökkentve (a hullám fölött, de a szöveg alatt) */
    z-index: 1;
    
    line-height: 0; /* Rés ellen */
    
    /* Mobil méretek: */
    width: 100%; 
    max-width: 500px; 
    
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .custom-image-wrapper img {
    display: block;
    width: 120%; /* Kicsit kilóg, hogy nagy legyen */
    height: auto;
    /* Biztos ami biztos, lehúzzuk 1 pixelre */
    margin-bottom: -50px; 
  }

  @media (max-width: 768px) {
  .custom-image-wrapper img {
     /* ne lógjon ki */
    margin-bottom: -450px;  /* ne rángassa az oldalt */
  }
}

  /* DESKTOP NÉZET BEÁLLÍTÁSOK */
  @media screen and (min-width: 990px) {
    .custom-content-wrapper {
      display: flex;
      flex-direction: row;
      align-items: center; /* Szöveg középen */
      height: 100%; 
      /* Desktopon a konténernek kell height, hogy az abszolút kép tudjon mihez igazodni */
      min-height: 700px; 
    }

    .custom-text-side {
      width: 50%;
      text-align: center;
      padding-bottom: 50px; /* Kicsit emeljük el a hullámtól */
    }

    /* KÉP DESKTOP POZÍCIÓ */
    .custom-image-wrapper {
      /* Reseteljük a mobil középre húzást */
      left: auto; 
      transform: none;
      
      right: -50px; /* Jobb szélre, kicsit kilógatva */
      bottom: 0; /* SZIGORÚAN ALJÁRA */
      
      width: 55%; /* Méret */
      max-width: none;
      justify-content: flex-end; 
    }

    .custom-image-wrapper img {
      width: 100%;
      max-width: 850px;
    }
  }

  /* TYPOGRAPHY (Változatlan) */
  .heading-style {
    font-family: 'Brush Script MT', 'Comic Sans MS', cursive;
    font-weight: 900;
    font-size: 3.5rem;
    color: {{ section.settings.brand_color }};
    transform: rotate(-6deg);
    display: inline-block;
    margin-bottom: 40px;
    text-shadow: 1px 1px 0 {{ section.settings.brand_color }};
    line-height: 1.2;
  }

  .stat-block { margin-bottom: 30px; }
  .stat-separator { width: 50%; height: 2px; background: {{ section.settings.brand_color }}; border: none; margin: 20px auto; opacity: 0.5; }
  .stat-top { display: block; font-size: 1.1rem; color: {{ section.settings.text_color }}; }
  .stat-big { display: block; font-size: 3.5rem; font-weight: 800; color: {{ section.settings.brand_color }}; line-height: 1; margin: 5px 0; }
  .stat-bottom { display: block; font-size: 1.1rem; color: {{ section.settings.text_color }}; }

{%- endstyle -%}

<div class="section-{{ section.id }}-root">
  
  <div class="custom-wave-bg">
    <svg viewBox="0 0 1440 320" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path fill="{{ section.settings.brand_color }}" fill-opacity="1" d="M0,288L48,272C96,256,192,224,288,218.7C384,213,480,235,576,250.7C672,267,768,277,864,250.7C960,224,1056,160,1152,128C1248,96,1344,96,1392,96L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    </svg>
  </div>

  <div class="custom-content-wrapper">
    
    <div class="custom-text-side">
      {%- if section.settings.heading != blank -%}
        <h2 class="heading-style">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="stat-block" {{ block.shopify_attributes }}>
          {%- if block.settings.top_text != blank -%}
            <span class="stat-top">{{ block.settings.top_text }}</span>
          {%- endif -%}
          {%- if block.settings.big_text != blank -%}
            <span class="stat-big">{{ block.settings.big_text }}</span>
          {%- endif -%}
          {%- if block.settings.bottom_text != blank -%}
            <span class="stat-bottom">{{ block.settings.bottom_text }}</span>
          {%- endif -%}
          {%- unless forloop.last -%}
            <hr class="stat-separator">
          {%- endunless -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="custom-image-wrapper">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: 'FruttaMax' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "FruttaMax Absolute Fix",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Háttérszín", "default": "#ffffff" },
    { "type": "color", "id": "brand_color", "label": "Brand Szín", "default": "#E80404" },
    { "type": "color", "id": "text_color", "label": "Szöveg Szín", "default": "#333333" },
    { "type": "text", "id": "heading", "label": "Főcím", "default": "De ce FruttaMax?" },
    { "type": "image_picker", "id": "image", "label": "Kép (PNG)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 60 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "top_text", "label": "Top Text", "default": "până la" },
        { "type": "text", "id": "big_text", "label": "Big Number", "default": "60%" },
        { "type": "text", "id": "bottom_text", "label": "Bottom Text", "default": "conținut de fructe" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FruttaMax Absolute Fix",
      "blocks": [
        { "type": "stat", "settings": { "big_text": "60%" } },
        { "type": "stat", "settings": { "big_text": "1:23" } },
        { "type": "stat", "settings": { "big_text": "75%" } }
      ]
    }
  ]
}
{% endschema %}