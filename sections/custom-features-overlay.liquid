{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    background-color: #000; /* Fallback szín */
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }

  /* HÁTTÉRKÉP */
  .custom-features__bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* OVERLAY (Színes réteg) */
  .custom-features__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  /* TARTALOM KONTÉNER */
  .custom-features__wrapper {
    position: relative;
    z-index: 2; /* Hogy a réteg fölött legyen */
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* GRID RENDSZER */
  .custom-features__grid {
    display: grid;
    grid-template-columns: 1fr; /* Mobilon 1 oszlop */
    gap: 40px;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .custom-features__grid {
      /* Desktopon annyi oszlop, ahány blokk van (max 3-4 szépen) */
      grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
      gap: 60px; /* Nagyobb térköz a szellősségért */
    }
  }

  /* BLOKK STÍLUS */
  .custom-feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* IKON */
  .custom-feature__icon {
    width: 60px;
    height: 60px;
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-feature__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ section.settings.text_color }}; /* Ikon színe követi a szöveget */
    stroke-width: 1.5px; /* Vékonyabb, elegánsabb vonalak */
  }

  /* CÍM */
  .custom-feature__title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 20px;
    color: inherit;
  }

  /* SZÖVEG */
  .custom-feature__text {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 1.1rem;
    line-height: 1.6; /* Nagyobb sorköz az olvashatóságért */
    color: inherit;
    opacity: 0.9;
    max-width: 500px; /* Hogy ne folyjon szét nagyon szélesre */
    margin: 0 auto;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2000 | image_tag: 
      loading: 'lazy', 
      class: 'custom-features__bg-image',
      alt: section.settings.bg_image.alt | escape 
    }}
  {%- endif -%}

  <div class="custom-features__overlay"></div>

  <div class="custom-features__wrapper">
    <div class="custom-features__grid">
      {%- for block in section.blocks -%}
        <div class="custom-feature-item" {{ block.shopify_attributes }}>
          
          <div class="custom-feature__icon">
            {%- case block.settings.icon -%}
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {%- when 'check' -%}
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.77 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
            {%- endcase -%}
          </div>

          <h3 class="custom-feature__title">{{ block.settings.heading }}</h3>

          <div class="custom-feature__text">{{ block.settings.text }}</div>

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Features (Overlay)",
  "settings": [
    {
      "type": "header",
      "content": "Fundal (Háttér)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagine Fundal"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Culoare Overlay",
      "default": "#E80404"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacitate Overlay",
      "default": 85
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Culoare Text & Icon",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spațiere"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Sus",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Jos",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Element",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Iconiță",
          "options": [
            { "value": "star", "label": "Stea (Minőség)" },
            { "value": "check", "label": "Bifă (Különbség)" },
            { "value": "heart", "label": "Inimă" },
            { "value": "leaf", "label": "Frunză (Természetes)" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titlu",
          "default": "Calitate"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Descriere",
          "default": "<p>Scrie aici textul despre standardele de calitate.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features (Overlay)",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "star",
            "heading": "Calitate",
            "text": "<p>Fabrica noastră funcționează conform standardelor stricte HACCP.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "check",
            "heading": "Diferența",
            "text": "<p>FruttaMax a revoluționat piața siropurilor cu un conținut de fructe de 50-60%.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}