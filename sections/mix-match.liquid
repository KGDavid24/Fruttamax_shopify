{% schema %}
{
  "name": "Mix and Match (6 buc)",
  "settings": [
    {
      "type": "header",
      "content": "Tartalom beállítások"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titlul secțiunii",
      "default": "Alege-ți pachetul de 6 produse!"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Kedvezmény kiemelő szöveg",
      "default": "🔥 10% EXTRA REDUCERE la tot pachetul! (Se aplică automat)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Selectează colecția"
    },
    {
      "type": "range",
      "id": "required_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Cantitate necesară",
      "default": 6
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Cod de reducere",
      "info": "Ex: sweet10. Se va aplica automat la adăugarea în coș.",
      "default": "sweet10"
    },
    {
      "type": "header",
      "content": "Szín beállítások"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Szekció háttere",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Fő szövegszín",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "color_discount_bg",
      "label": "Kedvezmény sáv háttere",
      "default": "#f0f0f5"
    },
    {
      "type": "color",
      "id": "color_discount_text",
      "label": "Kedvezmény sáv szövege és kerete",
      "default": "#666795"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Termékkártya háttere",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Kiválasztás színe (keret, pipa, progress bar)",
      "default": "#666795"
    },
    {
      "type": "color",
      "id": "color_btn_bg",
      "label": "Gomb alap színe",
      "default": "#666795"
    },
    {
      "type": "color",
      "id": "color_btn_text",
      "label": "Gomb szövege",
      "default": "#FFFF00"
    }
  ],
  "presets": [
    {
      "name": "Mix and Match Szekció"
    }
  ]
}
{% endschema %}

<style>
  #mix-match-{{ section.id }} {
    --bg-color: {{ section.settings.color_bg }};
    --text-color: {{ section.settings.color_text }};
    --card-bg: {{ section.settings.color_card_bg }};
    --accent-color: {{ section.settings.color_accent }};
    --btn-bg: {{ section.settings.color_btn_bg }};
    --btn-text: {{ section.settings.color_btn_text }};
    --discount-bg: {{ section.settings.color_discount_bg }};
    --discount-text: {{ section.settings.color_discount_text }};
  }

  .mix-match-wrapper {
    background-color: var(--bg-color);
    padding: 60px 20px;
  }
  
  .mix-match-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    color: var(--text-color);
    font-family: inherit;
  }

  .mix-match-title {
    font-size: 2.2em;
    font-weight: 800;
    margin-bottom: 15px;
    color: var(--text-color);
  }

  .mm-discount-banner {
    display: inline-block;
    background-color: var(--discount-bg);
    color: var(--discount-text);
    border: 2px dashed var(--discount-text);
    padding: 10px 24px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 1.1em;
    margin-bottom: 25px;
    animation: mmPulse 2s infinite;
  }

  @keyframes mmPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.03); }
    100% { transform: scale(1); }
  }

  .mix-match-status-container {
    max-width: 400px;
    margin: 0 auto 40px auto;
  }

  .mix-match-status {
    font-size: 1.2em;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .mm-progress-bar-bg {
    width: 100%;
    height: 8px;
    background-color: rgba(0,0,0,0.1);
    border-radius: 10px;
    overflow: hidden;
  }

  .mm-progress-bar-fill {
    height: 100%;
    background-color: var(--accent-color);
    width: 0%;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mix-match-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 25px;
    margin-bottom: 50px;
  }

  .mm-product-card {
    background-color: var(--card-bg);
    border: 2px solid transparent;
    border-radius: 16px;
    padding: 15px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .mm-product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }

  .mm-product-card.is-selected {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 1px var(--accent-color), 0 8px 25px rgba(0,0,0,0.1);
  }

  .mm-image-wrapper {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 15px;
    aspect-ratio: 3 / 4; /* Portré méret aránya */
  }

  .mm-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .mm-product-card:hover .mm-image-wrapper img {
    transform: scale(1.05);
  }

  .mm-check-icon {
    opacity: 0;
    transform: scale(0.5);
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--accent-color);
    color: #fff;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    line-height: 32px;
    text-align: center;
    font-weight: bold;
    font-size: 1.1em;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    z-index: 2;
  }

  .mm-product-card.is-selected .mm-check-icon {
    opacity: 1;
    transform: scale(1);
  }

  .mm-product-info {
    text-align: center;
  }

  .mm-product-title {
    font-weight: 700;
    font-size: 1.1em;
    margin: 0 0 8px 0;
    color: var(--text-color);
    line-height: 1.3;
  }

  .mm-product-price {
    color: var(--text-color);
    opacity: 0.8;
    margin: 0;
    font-weight: 500;
  }
  
  .mm-add-to-cart-btn {
    background-color: var(--btn-bg);
    color: var(--btn-text);
    font-weight: 800;
    letter-spacing: 1px;
    border: 2px solid transparent; /* Alapból átlátszó keret, hogy ne ugráljon hovernél */
    padding: 13px 28px; /* Kicsit korrigálva a 2px keret miatt */
    font-size: 1em; 
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    box-shadow: none; 
  }
  
 .mm-add-to-cart-btn:disabled {
    background-color: #fca5a5; /* Pasztell piros */
    color: #ffffff;
    cursor: not-allowed;
    border-color: transparent;
  }
  
  .mm-add-to-cart-btn:hover:not(:disabled) {
    background-color: #ffffff;
    color: #E80404;
    border: 2px solid #E80404; /* Fehér bg, piros font és piros keret */
    box-shadow: none; 
  }

  @media screen and (max-width: 768px) {
    .mix-match-wrapper {
      padding: 40px 10px;
    }
    
    .mix-match-title {
      font-size: 1.8em;
    }

    .mm-discount-banner {
      font-size: 0.95em;
      padding: 8px 16px;
    }

    .mix-match-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 30px;
    }

    .mm-product-card {
      padding: 10px;
      border-radius: 12px;
    }

    .mm-product-title {
      font-size: 0.9em;
      margin-bottom: 4px;
    }

    .mm-product-price {
      font-size: 0.85em;
    }

    .mm-check-icon {
      width: 24px;
      height: 24px;
      line-height: 24px;
      font-size: 0.9em;
      top: 5px;
      right: 5px;
    }

    .mm-add-to-cart-btn {
      width: 100%;
      padding: 13px 18px; 
      font-size: 1em; 
    }
  }
</style>

<div class="mix-match-wrapper" id="mix-match-{{ section.id }}">
  <div class="mix-match-container">
    <h2 class="mix-match-title">{{ section.settings.title }}</h2>
    
    {% if section.settings.discount_text != blank %}
      <div class="mm-discount-banner">
        {{ section.settings.discount_text }}
      </div>
    {% endif %}
    
    <div class="mix-match-status-container">
      <div class="mix-match-status">
        <span id="mm-counter-{{ section.id }}">0</span> / {{ section.settings.required_count }} selectate
      </div>
      <div class="mm-progress-bar-bg">
        <div class="mm-progress-bar-fill" id="mm-progress-{{ section.id }}"></div>
      </div>
    </div>

    <div class="mix-match-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection %}
        {% for product in collection.products %}
          <div class="mm-product-card" data-variant-id="{{ product.variants.first.id }}">
            <div class="mm-image-wrapper">
              <img src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
              <div class="mm-check-icon">✓</div>
            </div>
            <div class="mm-product-info">
              <p class="mm-product-title">{{ product.title }}</p>
              <p class="mm-product-price">{{ product.price | money }}</p>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p>Te rugăm să selectezi o colecție din setări!</p>
      {% endif %}
    </div>

    <div class="mix-match-actions">
      <button id="mm-add-btn-{{ section.id }}" class="mm-add-to-cart-btn" disabled>
        Adaugă pachetul în coș
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const container = document.getElementById('mix-match-{{ section.id }}');
    const products = container.querySelectorAll('.mm-product-card');
    const counterDisplay = document.getElementById('mm-counter-{{ section.id }}');
    const progressBar = document.getElementById('mm-progress-{{ section.id }}');
    const addBtn = document.getElementById('mm-add-btn-{{ section.id }}');
    
    const requiredCount = {{ section.settings.required_count }};
    const discountCode = "{{ section.settings.discount_code | default: 'sweet10' }}".trim();
    let selectedVariants = [];

    function updateUI() {
      counterDisplay.innerText = selectedVariants.length;
      
      const progressPercentage = (selectedVariants.length / requiredCount) * 100;
      progressBar.style.width = progressPercentage + '%';

      if (selectedVariants.length === requiredCount) {
        addBtn.disabled = false;
      } else {
        addBtn.disabled = true;
      }
    }

    products.forEach(product => {
      product.addEventListener('click', function() {
        const variantId = this.getAttribute('data-variant-id');
        const isSelected = this.classList.contains('is-selected');

        if (isSelected) {
          this.classList.remove('is-selected');
          selectedVariants = selectedVariants.filter(id => id !== variantId);
        } else {
          if (selectedVariants.length >= requiredCount) {
            alert(`Ai selectat deja ${requiredCount} produse! Pentru a alege un alt produs, te rugăm să deselectezi unul.`);
            return;
          }
          this.classList.add('is-selected');
          selectedVariants.push(variantId);
        }

        updateUI();
      });
    });

    addBtn.addEventListener('click', function() {
      if (selectedVariants.length !== requiredCount) return;

      addBtn.innerText = "Se adaugă...";
      addBtn.disabled = true;

      const itemsToAdd = selectedVariants.map(id => ({
        id: parseInt(id),
        quantity: 1
      }));

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ items: itemsToAdd })
      })
      .then(response => response.json())
      .then(data => {
        if (discountCode !== "") {
          window.location.href = '/discount/' + discountCode + '?redirect=/cart';
        } else {
          window.location.href = '/cart';
        }
      })
      .catch((error) => {
        console.error('Eroare:', error);
        alert('A apărut o eroare la adăugarea în coș.');
        addBtn.innerText = "Adaugă pachetul în coș";
        addBtn.disabled = false;
      });
    });
  });
</script>