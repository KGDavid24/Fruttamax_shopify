{% doc %}
  @prompt
    Add a scrolling announcement bar at the top of the page that loops continuously. The bar should show two language versions depending on the active locale.
    For the Romanian locale show: 🏆 Câștigă 10.000 lei — Fotografiază FruttaMax în cel mai random context! Participă acum → and link it to https://fruttamax.ro/pages/campainie-unde-fruttamax-2026
    For the Hungarian locale show: 🏆 Nyerj 10.000 lejt — Fotózd le a FruttaMaxot a legrandomabb helyzetben! Részt veszek → and link it to https://fruttamax.ro/hu/pages/fruttamax-kampany-nyerj-10000-lejt
    The bar should use a red background (#d0322b) with white text, the text should scroll horizontally in a continuous loop, and the entire bar should be clickable., make it pop more and the scrolling speed is not working, also make it fullwidth, the scroll should be setable, the direction of it. Make sure the thext goes around, goes out at one end of the screen and appears at the other end., still a bit buggy when the text is going around also the speed is not working properly, the settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  announcement-bar-{{ ai_gen_id }},
  .ai-announcement-bar-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    z-index: 1000;
    display: block;
  }

  .ai-announcement-bar-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.bar_height }}px 0;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
  }

  .ai-announcement-bar-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-scroll-{{ ai_gen_id }}-{{ block.settings.scroll_direction }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-announcement-bar-content-{{ ai_gen_id }} {
    display: inline-flex;
    white-space: nowrap;
    padding: 0 {{ block.settings.spacing_between }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    align-items: center;
  }

  @keyframes ai-scroll-{{ ai_gen_id }}-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes ai-scroll-{{ ai_gen_id }}-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }} class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% liquid
    if request.locale.iso_code == 'hu'
      assign announcement_text = block.settings.text_hu
      assign announcement_link = block.settings.link_hu
    else
      assign announcement_text = block.settings.text_ro
      assign announcement_link = block.settings.link_ro
    endif
  %}

  <a href="{{ announcement_link }}" class="ai-announcement-bar-link-{{ ai_gen_id }}">
    <div class="ai-announcement-bar-track-{{ ai_gen_id }}">
      {% for i in (1..30) %}
        <div class="ai-announcement-bar-content-{{ ai_gen_id }}">
          {{ announcement_text }}
        </div>
      {% endfor %}
    </div>
  </a>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAnimation();
      }

      setupAnimation() {
        const track = this.querySelector('.ai-announcement-bar-track-{{ ai_gen_id }}');
        if (!track) return;

        track.addEventListener('mouseenter', () => {
          track.style.animationPlayState = 'paused';
        });

        track.addEventListener('mouseleave', () => {
          track.style.animationPlayState = 'running';
        });
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>

